@using SOS.Models.MsK
@if (ViewBag.AktifDuyuru != null)
{
    var duyuru = (TBL_DUYURU)ViewBag.AktifDuyuru;
    <div id="duyuru-modal" class="fixed inset-0 z-[9990] flex items-center justify-center">
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="kapatDuyuru()"></div>
        <div class="relative z-10 bg-[#1e293b] border border-slate-700/60 rounded-2xl shadow-2xl flex flex-col"
             style="width:min(860px,94vw); height:min(88vh,780px);">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-700/50 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-blue-900/40 border border-blue-700/40 flex items-center justify-center">
                        <i class="bi bi-megaphone text-blue-400 text-sm"></i>
                    </div>
                    <span class="text-white font-semibold text-base">Duyuru</span>
                    <span class="text-slate-500 text-xs">@duyuru.BitisTarihi.ToString("dd.MM.yyyy") tarihine kadar geçerli</span>
                </div>
                <button onclick="kapatDuyuru()" class="text-slate-400 hover:text-white transition-colors">
                    <i class="bi bi-x-lg text-lg"></i>
                </button>
            </div>
            <div id="duyuru-pdf-container" class="flex-1 overflow-y-auto bg-slate-900/60 rounded-b-2xl" style="padding:12px">
                <div id="duyuru-pdf-pages" class="flex flex-col gap-2"></div>
            </div>
        </div>
    </div>
    <script src="https://unpkg.com/pdfjs-dist@@3.11.174/build/pdf.min.js"></script>
    <script>
        function kapatDuyuru() { document.getElementById('duyuru-modal').remove(); }
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') kapatDuyuru(); });
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://unpkg.com/pdfjs-dist@@3.11.174/build/pdf.worker.min.js';
        (function() {
            var container = document.getElementById('duyuru-pdf-container');
            var pages = document.getElementById('duyuru-pdf-pages');

            // PDF verisi zaten sayfada mevcut, ikinci HTTP isteği gerekmez
            var b64 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(duyuru.PdfIcerik));
            var binary = atob(b64.replace(/\s/g, ''));
            var bytes = new Uint8Array(binary.length);
            for (var i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);

            pdfjsLib.getDocument({ data: bytes }).promise.then(function(pdf) {
                var w = Math.max(container.clientWidth - 24, 200);
                var canvases = [];
                for (var i = 1; i <= pdf.numPages; i++) {
                    var canvas = document.createElement('canvas');
                    canvas.style.cssText = 'border-radius:6px;display:block;';
                    pages.appendChild(canvas);
                    canvases.push({ canvas: canvas, num: i });
                }
                canvases.forEach(function(item) {
                    pdf.getPage(item.num).then(function(page) {
                        var scale = w / page.getViewport({ scale: 1 }).width;
                        var vp = page.getViewport({ scale: scale });
                        item.canvas.width = vp.width;
                        item.canvas.height = vp.height;
                        page.render({ canvasContext: item.canvas.getContext('2d'), viewport: vp });
                    }).catch(function(err) { console.error('Sayfa render hatası:', err); });
                });
            }).catch(function(err) {
                console.error('PDF yükleme hatası:', err);
                pages.innerHTML = '<div style="text-align:center;padding:40px;color:#f87171;font-size:14px;">PDF yüklenemedi.</div>';
            });
        })();
    </script>
}

