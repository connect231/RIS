@using Microsoft.Extensions.Configuration
@using Microsoft.AspNetCore.Identity
@using SOS.Models.Kullanici
@using SOS.Services
@inject IConfiguration Configuration
@inject UserManager<AppUser> UserManager
@inject IUrlEncryptionService UrlEncryption

@{
    var appUser = await UserManager.GetUserAsync(User);
    var userInitial = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?";
    var userName = User.Identity?.Name ?? "Kullanıcı";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 99px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,0.2); }
        * { scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.1) transparent; }

        [x-cloak] { display: none !important; }

        /* Hyper-minimalist sidebar */
        .mini-sidebar {
            width: 64px;
            max-width: 200px;
            background: #ede9fe;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            border-right: 1px solid rgba(139,92,246,0.12);
        }
        .mini-sidebar:hover {
            width: 200px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 14px;
            width: 100%;
            padding: 14px 20px;
            color: #7c3aed;
            text-decoration: none;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            white-space: nowrap;
        }
        .sidebar-link:hover {
            background: rgba(139,92,246,0.12);
            color: #4f46e5;
        }
        .sidebar-link.active {
            background: rgba(99,102,241,0.18);
            color: #4338ca;
        }
        .sidebar-link i {
            font-size: 22px;
            min-width: 24px;
            text-align: center;
            flex-shrink: 0;
        }
        .sidebar-link-text {
            font-size: 14px;
            font-weight: 500;
            opacity: 0;
            transform: translateX(-10px);
            transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s, transform 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s;
        }
        .mini-sidebar:hover .sidebar-link-text {
            opacity: 1;
            transform: translateX(0);
        }
        .sidebar-bottom {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            padding: 12px 0;
            width: 100%;
        }
        .sidebar-bottom .sidebar-link {
            padding: 10px 20px;
        }
        .sidebar-avatar {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            background: rgba(99,102,241,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6366f1;
            font-size: 14px;
            font-weight: 600;
            flex-shrink: 0;
        }
        .sidebar-username {
            font-size: 12px;
            font-weight: 500;
            color: #6366f1;
            opacity: 0;
            white-space: nowrap;
            transition: opacity 0.25s ease 0.1s;
        }
        .mini-sidebar:hover .sidebar-username {
            opacity: 1;
        }
    </style>
</head>
<body class="bg-[#f5f5f7] text-[#1d1d1f] h-screen flex overflow-hidden">

    <!-- HYPER-MINIMALIST SIDEBAR -->
    <aside class="mini-sidebar">
        <a href="@Url.Action("Index", "Cockpit")" class="sidebar-link active">
            <i class="bi bi-bar-chart-line"></i>
            <span class="sidebar-link-text">Cockpit</span>
        </a>

        <div class="sidebar-bottom" style="margin-top:auto;">
            <!-- User -->
            <div class="sidebar-link" style="cursor:default; pointer-events:none;">
                <div class="sidebar-avatar">@userInitial</div>
                <span class="sidebar-username">@userName</span>
            </div>
            <!-- Logout -->
            <a href="/Account/LogOut" class="sidebar-link" style="color:#ef4444;">
                <i class="bi bi-box-arrow-right"></i>
                <span class="sidebar-link-text" style="color:#ef4444;">Çıkış Yap</span>
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 overflow-y-auto p-8">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
