@using Microsoft.Extensions.Configuration
@using Microsoft.AspNetCore.Identity
@using SOS.Models.Kullanici
@using SOS.Services
@inject IConfiguration Configuration
@inject UserManager<AppUser> UserManager
@inject IUrlEncryptionService UrlEncryption

@{
    var appUser = await UserManager.GetUserAsync(User);
    var userInitial = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?";
    var userName = User.Identity?.Name ?? "Kullanıcı";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font preload: FOUT/titreme önleme -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/tailwind.css">
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        /* ═══ APPLE-QUALITY RENDERING ═══ */
        *, *::before, *::after {
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            text-rendering: optimizeLegibility;
            -webkit-tap-highlight-color: transparent;
        }

        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', system-ui, sans-serif;
            font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
            font-optical-sizing: auto;
        }

        html {
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
            font-synthesis: none;
        }

        /* GPU-only animasyonlar: sadece transform + opacity = 60fps */
        .gpu { will-change: transform, opacity; transform: translateZ(0); backface-visibility: hidden; }

        /* Apple easing curves */
        :root {
            --ease-apple: cubic-bezier(0.25, 0.1, 0.25, 1.0);
            --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-in-out: cubic-bezier(0.45, 0, 0.55, 1);
            --duration-fast: 0.2s;
            --duration-normal: 0.35s;
            --duration-slow: 0.5s;
        }

        /* Smooth number transitions */
        .num-transition {
            font-variant-numeric: tabular-nums;
            letter-spacing: -0.02em;
            transition: none; /* JS handles animation */
        }

        /* macOS scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.08); border-radius: 99px; transition: background 0.2s; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,0.18); }
        * { scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.08) transparent; }

        /* Content fade-in on load (no flash) */
        .fade-ready { opacity: 0; transform: translateY(8px); }
        .fade-in {
            opacity: 1 !important;
            transform: translateY(0) !important;
            transition: opacity var(--duration-slow) var(--ease-out-expo),
                        transform var(--duration-slow) var(--ease-out-expo);
        }

        /* Smooth value update flash */
        .value-updated {
            animation: value-pulse 0.6s var(--ease-apple);
        }
        @@keyframes value-pulse {
            0% { opacity: 0.4; transform: scale(0.96); }
            50% { opacity: 1; transform: scale(1.02); }
            100% { opacity: 1; transform: scale(1); }
        }

        /* Deep Blue Navy Sidebar */
        .nav-sidebar {
            width: 68px;
            max-width: 220px;
            background: linear-gradient(180deg, #1e3a8a 0%, #1e40af 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            flex-shrink: 0;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            border-right: 1px solid rgba(255,255,255,0.06);
            box-shadow: 4px 0 24px rgba(30,58,138,0.15);
        }
        .nav-sidebar:hover {
            width: 220px;
        }

        /* Logo area */
        .sidebar-logo {
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            margin-bottom: 8px;
        }
        .sidebar-logo-text {
            font-size: 16px;
            font-weight: 700;
            color: white;
            letter-spacing: -0.02em;
            opacity: 0;
            transform: translateX(-8px);
            transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s, transform 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s;
            white-space: nowrap;
        }
        .nav-sidebar:hover .sidebar-logo-text {
            opacity: 1;
            transform: translateX(0);
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 14px;
            width: 100%;
            padding: 12px 22px;
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            white-space: nowrap;
            border-left: 3px solid transparent;
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.9);
            border-left-color: rgba(96,165,250,0.4);
        }
        .nav-link.active {
            background: rgba(255,255,255,0.1);
            color: white;
            border-left-color: #60a5fa;
        }
        .nav-link i {
            font-size: 20px;
            min-width: 24px;
            text-align: center;
            flex-shrink: 0;
        }
        .nav-link-text {
            font-size: 13px;
            font-weight: 500;
            opacity: 0;
            transform: translateX(-8px);
            transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s, transform 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s;
        }
        .nav-sidebar:hover .nav-link-text {
            opacity: 1;
            transform: translateX(0);
        }

        /* Mobile sidebar */
        @@media (max-width: 767px) {
            .nav-sidebar {
                position: fixed;
                left: 0; top: 0; bottom: 0;
                z-index: 45;
                width: 220px !important;
                transform: translateX(-100%);
                transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .nav-sidebar.mobile-open {
                transform: translateX(0);
            }
            .nav-sidebar .sidebar-logo-text,
            .nav-sidebar .nav-link-text,
            .nav-sidebar .sidebar-user-text { opacity: 1; transform: none; }
            main { padding: 16px !important; padding-top: 56px !important; }
        }

        /* Bottom section */
        .sidebar-footer {
            margin-top: auto;
            width: 100%;
            border-top: 1px solid rgba(255,255,255,0.08);
            padding: 12px 0;
        }
        .sidebar-avatar-wrap {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: rgba(96,165,250,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #93c5fd;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
        }
        .sidebar-user-text {
            font-size: 12px;
            font-weight: 500;
            color: rgba(255,255,255,0.6);
            opacity: 0;
            white-space: nowrap;
            transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s;
        }
        .nav-sidebar:hover .sidebar-user-text {
            opacity: 1;
        }
    </style>
</head>
<body class="bg-[#f8fafc] text-[#1e293b] h-screen flex overflow-hidden">

    <!-- MOBILE HAMBURGER -->
    <button onclick="document.getElementById('sidebar').classList.add('mobile-open');document.getElementById('sidebarOverlay').classList.remove('hidden');"
            class="fixed top-4 left-4 z-50 w-10 h-10 rounded-xl bg-white shadow-lg flex items-center justify-center md:hidden">
        <i class="bi bi-list text-lg text-[#1e293b]"></i>
    </button>
    <div id="sidebarOverlay" class="hidden fixed inset-0 bg-black/30 backdrop-blur-sm z-40 md:hidden"
         onclick="document.getElementById('sidebar').classList.remove('mobile-open');this.classList.add('hidden');"></div>

    <!-- DEEP BLUE SIDEBAR -->
    <aside id="sidebar" class="nav-sidebar">
        <!-- Logo -->
        <div class="sidebar-logo">
            <svg width="28" height="28" viewBox="0 0 36 36" fill="none" class="flex-shrink-0">
                <rect width="36" height="36" rx="10" fill="rgba(255,255,255,0.12)"/>
                <path d="M22 12.5c0-1.5-1.5-2.5-4-2.5s-4 1-4 2.5c0 2 2.5 2.5 4 3.2s4 1.2 4 3.3c0 1.5-1.5 2.5-4 2.5s-4-1-4-2.5" stroke="white" stroke-width="2" stroke-linecap="round" fill="none"/>
                <circle cx="27" cy="9" r="2.5" fill="#60a5fa"/>
            </svg>
            <span class="sidebar-logo-text">SOS</span>
        </div>

        <!-- Nav -->
        <nav class="w-full flex-1 py-2">
            <a href="@Url.Action("Index", "Cockpit")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cockpit" ? "active" : "")" title="Finansal Cockpit">
                <i class="bi bi-bar-chart-line"></i>
                <span class="nav-link-text">Cockpit</span>
            </a>
            <a href="@Url.Action("Index", "FirsatAnaliz")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "FirsatAnaliz" ? "active" : "")" title="Fırsat Analizi">
                <i class="bi bi-graph-up-arrow"></i>
                <span class="nav-link-text">Fırsat Analizi</span>
            </a>
            <a href="@Url.Action("Index", "Tahakkuk")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tahakkuk" ? "active" : "")" title="Tahakkuk Yönetimi">
                <i class="bi bi-calendar-check"></i>
                <span class="nav-link-text">Tahakkuk</span>
            </a>
            <a href="@Url.Action("Index", "Parametre")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Parametre" ? "active" : "")" title="Parametreler">
                <i class="bi bi-sliders"></i>
                <span class="nav-link-text">Parametreler</span>
            </a>
        </nav>

        <!-- Footer -->
        <div class="sidebar-footer">
            <div class="nav-link" style="cursor:default; pointer-events:none;">
                <div class="sidebar-avatar-wrap">@userInitial</div>
                <span class="sidebar-user-text">@userName</span>
            </div>
            <a href="/Account/LogOut" class="nav-link" style="color:rgba(248,113,113,0.8);" title="Çıkış Yap">
                <i class="bi bi-box-arrow-right"></i>
                <span class="nav-link-text" style="color:rgba(248,113,113,0.8);">Çıkış</span>
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 overflow-y-auto p-8" style="background:#f8fafc;">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
    // ═══ APPLE-QUALITY GLOBAL UTILITIES ═══
    (function(){
        'use strict';

        // Sayfa yüklendikten sonra fade-in (FOUC önleme)
        document.addEventListener('DOMContentLoaded', function(){
            requestAnimationFrame(function(){
                document.querySelectorAll('.fade-ready').forEach(function(el, i){
                    setTimeout(function(){ el.classList.add('fade-in'); }, i * 60);
                });
            });
        });

        // ═══ COUNT-UP: requestAnimationFrame ile 60fps sayı animasyonu ═══
        // Eski değerden yeni değere geçiş (0'dan değil)
        window.countUp = function(el, target, duration, prefix, suffix) {
            if (!el) return;
            prefix = prefix || '';
            suffix = suffix || '';
            duration = duration || 1200;
            var formatter = new Intl.NumberFormat('tr-TR', { maximumFractionDigits: 0 });

            // Mevcut değeri oku — 0'dan başlama, eski değerden devam et
            var raw = (el.textContent || '').replace(/[^0-9]/g, '');
            var from = parseInt(raw, 10) || 0;
            if (from === target) return;

            var startTime = null;
            function ease(t) { return t === 1 ? 1 : 1 - Math.pow(2, -10 * t); }

            // Önceki animasyonu iptal et
            if (el._countUpId) cancelAnimationFrame(el._countUpId);

            function step(timestamp) {
                if (!startTime) startTime = timestamp;
                var progress = Math.min((timestamp - startTime) / duration, 1);
                var current = Math.floor(from + ease(progress) * (target - from));
                el.textContent = prefix + formatter.format(current) + suffix;
                if (progress < 1) {
                    el._countUpId = requestAnimationFrame(step);
                } else {
                    el.textContent = prefix + formatter.format(target) + suffix;
                    el._countUpId = null;
                }
            }

            el._countUpId = requestAnimationFrame(step);
        };

        // ═══ SMOOTH VALUE UPDATE: Eski değerden yeniye geçiş ═══
        window.smoothUpdate = function(el, newText, animate) {
            if (!el || el.textContent === newText) return;
            if (animate !== false) {
                el.style.transition = 'none';
                el.style.opacity = '0.4';
                el.style.transform = 'translateY(2px)';
                requestAnimationFrame(function(){
                    el.style.transition = 'opacity 0.2s cubic-bezier(0.16,1,0.3,1), transform 0.2s cubic-bezier(0.16,1,0.3,1)';
                    el.textContent = newText;
                    el.style.opacity = '1';
                    el.style.transform = 'translateY(0)';
                });
            } else {
                el.textContent = newText;
            }
        };

        // ═══ SMOOTH HTML UPDATE: innerHTML için GPU fade geçiş (setTimeout yok) ═══
        window.smoothHtmlUpdate = function(el, newHtml) {
            if (!el) return;
            el.style.transition = 'none';
            el.style.opacity = '0';
            el.style.transform = 'translateY(2px)';
            requestAnimationFrame(function(){
                el.innerHTML = newHtml;
                el.style.transition = 'opacity 0.3s cubic-bezier(0.16,1,0.3,1), transform 0.3s cubic-bezier(0.16,1,0.3,1)';
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
            });
        };

    })();
    </script>
</body>
</html>
