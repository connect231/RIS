@using Microsoft.Extensions.Configuration
@using Microsoft.AspNetCore.Identity
@using SOS.Models.Kullanici
@using SOS.Services
@inject IConfiguration Configuration
@inject UserManager<AppUser> UserManager
@inject IUrlEncryptionService UrlEncryption

@{
    var appUser = await UserManager.GetUserAsync(User);
    var userInitial = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?";
    var userName = User.Identity?.Name ?? "Kullanıcı";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.08); border-radius: 99px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,0.15); }
        * { scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.08) transparent; }

        /* Deep Blue Navy Sidebar */
        .nav-sidebar {
            width: 68px;
            max-width: 220px;
            background: linear-gradient(180deg, #1e3a8a 0%, #1e40af 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            flex-shrink: 0;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            border-right: 1px solid rgba(255,255,255,0.06);
            box-shadow: 4px 0 24px rgba(30,58,138,0.15);
        }
        .nav-sidebar:hover {
            width: 220px;
        }

        /* Logo area */
        .sidebar-logo {
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            margin-bottom: 8px;
        }
        .sidebar-logo-text {
            font-size: 16px;
            font-weight: 700;
            color: white;
            letter-spacing: -0.02em;
            opacity: 0;
            transform: translateX(-8px);
            transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s, transform 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s;
            white-space: nowrap;
        }
        .nav-sidebar:hover .sidebar-logo-text {
            opacity: 1;
            transform: translateX(0);
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 14px;
            width: 100%;
            padding: 12px 22px;
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            white-space: nowrap;
            border-left: 3px solid transparent;
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.9);
            border-left-color: rgba(96,165,250,0.4);
        }
        .nav-link.active {
            background: rgba(255,255,255,0.1);
            color: white;
            border-left-color: #60a5fa;
        }
        .nav-link i {
            font-size: 20px;
            min-width: 24px;
            text-align: center;
            flex-shrink: 0;
        }
        .nav-link-text {
            font-size: 13px;
            font-weight: 500;
            opacity: 0;
            transform: translateX(-8px);
            transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s, transform 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s;
        }
        .nav-sidebar:hover .nav-link-text {
            opacity: 1;
            transform: translateX(0);
        }

        /* Bottom section */
        .sidebar-footer {
            margin-top: auto;
            width: 100%;
            border-top: 1px solid rgba(255,255,255,0.08);
            padding: 12px 0;
        }
        .sidebar-avatar-wrap {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: rgba(96,165,250,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #93c5fd;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
        }
        .sidebar-user-text {
            font-size: 12px;
            font-weight: 500;
            color: rgba(255,255,255,0.6);
            opacity: 0;
            white-space: nowrap;
            transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1) 0.1s;
        }
        .nav-sidebar:hover .sidebar-user-text {
            opacity: 1;
        }
    </style>
</head>
<body class="bg-[#f8fafc] text-[#1e293b] h-screen flex overflow-hidden">

    <!-- DEEP BLUE SIDEBAR -->
    <aside class="nav-sidebar">
        <!-- Logo -->
        <div class="sidebar-logo">
            <svg width="28" height="28" viewBox="0 0 36 36" fill="none" class="flex-shrink-0">
                <rect width="36" height="36" rx="10" fill="rgba(255,255,255,0.12)"/>
                <path d="M22 12.5c0-1.5-1.5-2.5-4-2.5s-4 1-4 2.5c0 2 2.5 2.5 4 3.2s4 1.2 4 3.3c0 1.5-1.5 2.5-4 2.5s-4-1-4-2.5" stroke="white" stroke-width="2" stroke-linecap="round" fill="none"/>
                <circle cx="27" cy="9" r="2.5" fill="#60a5fa"/>
            </svg>
            <span class="sidebar-logo-text">SOS</span>
        </div>

        <!-- Nav -->
        <nav class="w-full flex-1 py-2">
            <a href="@Url.Action("Index", "Cockpit")" class="nav-link active">
                <i class="bi bi-bar-chart-line"></i>
                <span class="nav-link-text">Cockpit</span>
            </a>
        </nav>

        <!-- Footer -->
        <div class="sidebar-footer">
            <div class="nav-link" style="cursor:default; pointer-events:none;">
                <div class="sidebar-avatar-wrap">@userInitial</div>
                <span class="sidebar-user-text">@userName</span>
            </div>
            <a href="/Account/LogOut" class="nav-link" style="color:rgba(248,113,113,0.8);">
                <i class="bi bi-box-arrow-right"></i>
                <span class="nav-link-text" style="color:rgba(248,113,113,0.8);">Çıkış</span>
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 overflow-y-auto p-8" style="background:#f8fafc;">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
