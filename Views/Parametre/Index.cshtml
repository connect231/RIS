@{
    ViewData["Title"] = "Parametreler";
    var selectedYil = (int)ViewBag.SelectedYil;
    var hedefler = (List<SOS.Models.MsK.TBLSOS_HEDEF_AYLIK>)ViewBag.Hedefler;
    var anaUrunler = (List<SOS.Models.MsK.TBLSOS_ANA_URUN>)ViewBag.AnaUrunler;
    var toplamHedef = (decimal)ViewBag.ToplamHedef;
    var aylar = new[] { "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };
}

<!-- HEADER -->
<div class="flex items-center justify-between mb-6 fade-ready">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-2xl bg-blue-100 flex items-center justify-center">
            <i class="bi bi-sliders text-blue-700 text-lg"></i>
        </div>
        <div>
            <h1 class="text-xl font-bold text-[#1e293b] tracking-tight">Parametreler</h1>
            <p class="text-[11px] text-slate-400">Hedefler &middot; Ürün eşleştirme &middot; Genel ayarlar</p>
        </div>
    </div>
</div>

<!-- TAB NAV -->
<div class="flex gap-1 mb-5 fade-ready">
    <button onclick="switchTab('hedefler')" id="tab-hedefler" class="param-tab active px-4 py-2 rounded-xl text-xs font-semibold transition-all">
        <i class="bi bi-bullseye mr-1.5"></i>Aylık hedefler
    </button>
    <button onclick="switchTab('urunler')" id="tab-urunler" class="param-tab px-4 py-2 rounded-xl text-xs font-semibold transition-all">
        <i class="bi bi-box-seam mr-1.5"></i>Ürün eşleştirme
    </button>
    <button onclick="switchTab('ayarlar')" id="tab-ayarlar" class="param-tab px-4 py-2 rounded-xl text-xs font-semibold transition-all">
        <i class="bi bi-gear mr-1.5"></i>Genel ayarlar
    </button>
</div>

<!-- ═══ TAB 1: AYLIK HEDEFLER ═══ -->
<div id="panel-hedefler" class="param-panel fade-ready">
    <!-- Yıl seçimi + toplam -->
    <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
            <select id="yilSelect" onchange="location.href='/Parametre/Index?yil='+this.value"
                    class="text-sm px-3 py-1.5 rounded-xl border border-slate-200 bg-white text-slate-700 font-semibold focus:outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-100">
                @for (int y = DateTime.Now.Year + 1; y >= 2025; y--)
                {
                    if (y == selectedYil) { <option value="@y" selected>@y</option> }
                    else { <option value="@y">@y</option> }
                }
            </select>
            <span class="text-xs text-slate-400">Genel hedefler</span>
        </div>
        <div class="flex items-center gap-3">
            <div class="text-right">
                <p class="text-[10px] text-slate-400">Yıllık toplam</p>
                <p id="yillikToplam" class="text-lg font-bold text-[#1e293b]">₺@toplamHedef.ToString("N0")</p>
            </div>
            <button onclick="saveHedefler()" id="btnSave"
                    class="px-4 py-2 rounded-xl bg-blue-600 text-white text-xs font-semibold hover:bg-blue-700 transition-colors flex items-center gap-1.5 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                <i class="bi bi-check2-circle"></i> Kaydet
            </button>
        </div>
    </div>

    <!-- 12 aylık grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        @for (int ay = 1; ay <= 12; ay++)
        {
            var hedef = hedefler.FirstOrDefault(h => h.Ay == ay);
            var tutar = hedef?.HedefTutar ?? 0;
            var ceyrek = (ay - 1) / 3 + 1;
            var ceyrekRenk = ceyrek switch {
                1 => "border-l-blue-400",
                2 => "border-l-emerald-400",
                3 => "border-l-amber-400",
                _ => "border-l-rose-400"
            };
            <div class="bg-white rounded-xl border border-slate-100 p-4 border-l-4 @ceyrekRenk hover:shadow-md transition-shadow group">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-semibold text-slate-500">@aylar[ay - 1]</span>
                    <span class="text-[9px] text-slate-300 font-medium">@ceyrek. çeyrek</span>
                </div>
                <div class="flex items-center gap-1">
                    <span class="text-sm text-slate-400 font-medium">₺</span>
                    <input type="text"
                           id="hedef-@ay"
                           data-ay="@ay"
                           value="@(tutar > 0 ? (tutar / 1_000_000m).ToString("N0") : "")"
                           placeholder="0"
                           oninput="onHedefInput(this)"
                           class="hedef-input w-full text-xl font-bold text-[#1e293b] bg-transparent border-none outline-none placeholder:text-slate-200 focus:text-blue-700 transition-colors" />
                    <span class="text-xs text-slate-300 font-medium">M</span>
                </div>
                <div class="h-1 bg-slate-100 rounded-full mt-3 overflow-hidden">
                    <div class="h-full rounded-full transition-all duration-500"
                         style="width: @(toplamHedef > 0 ? Math.Round(tutar / toplamHedef * 100, 0) : 0)%; background: linear-gradient(90deg, #3b82f6, #60a5fa);"></div>
                </div>
            </div>
        }
    </div>

    <!-- Çeyrek özet -->
    <div class="grid grid-cols-4 gap-3 mt-4">
        @for (int q = 1; q <= 4; q++)
        {
            var qStart = (q - 1) * 3 + 1;
            var qToplam = hedefler.Where(h => h.Ay >= qStart && h.Ay < qStart + 3).Sum(h => h.HedefTutar);
            var qRenk = q switch { 1 => "bg-blue-50 text-blue-700", 2 => "bg-emerald-50 text-emerald-700", 3 => "bg-amber-50 text-amber-700", _ => "bg-rose-50 text-rose-700" };
            <div class="@qRenk rounded-xl p-3 text-center">
                <p class="text-[10px] font-semibold opacity-60">@q. Çeyrek</p>
                <p id="q@(q)-toplam" class="text-sm font-bold mt-0.5">₺@((qToplam / 1_000_000m).ToString("N0"))M</p>
            </div>
        }
    </div>
</div>

<!-- ═══ TAB 2: ÜRÜN EŞLEŞTİRME (placeholder) ═══ -->
<div id="panel-urunler" class="param-panel hidden fade-ready">
    <div class="bg-white rounded-xl border border-slate-100 p-8 text-center">
        <i class="bi bi-box-seam text-4xl text-slate-200"></i>
        <p class="text-sm text-slate-400 mt-3">Ürün eşleştirme ekranı yapım aşamasında</p>
        <p class="text-[10px] text-slate-300 mt-1">8 ana ürün &middot; 145 stok kodu eşleşmesi</p>
    </div>
</div>

<!-- ═══ TAB 3: GENEL AYARLAR (placeholder) ═══ -->
<div id="panel-ayarlar" class="param-panel hidden fade-ready">
    <div class="bg-white rounded-xl border border-slate-100 p-8 text-center">
        <i class="bi bi-gear text-4xl text-slate-200"></i>
        <p class="text-sm text-slate-400 mt-3">Genel ayarlar ekranı yapım aşamasında</p>
    </div>
</div>

@section Scripts {
<style>
    .param-tab { background: #f1f5f9; color: #64748b; }
    .param-tab.active { background: #1e40af; color: white; box-shadow: 0 2px 8px rgba(30,64,175,0.25); }
    .param-tab:not(.active):hover { background: #e2e8f0; }
    .hedef-input::-webkit-outer-spin-button,
    .hedef-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .hedef-input { -moz-appearance: textfield; }
</style>
<script>
(function(){
    'use strict';

    var dirty = false;
    var yil = @selectedYil;
    var fmtN = new Intl.NumberFormat('tr-TR', { maximumFractionDigits: 0 });

    // Tab switch
    window.switchTab = function(tab) {
        document.querySelectorAll('.param-tab').forEach(t => t.classList.remove('active'));
        document.getElementById('tab-' + tab).classList.add('active');
        document.querySelectorAll('.param-panel').forEach(p => p.classList.add('hidden'));
        document.getElementById('panel-' + tab).classList.remove('hidden');
    };

    // Hedef input değişikliği
    window.onHedefInput = function(el) {
        dirty = true;
        document.getElementById('btnSave').disabled = false;
        updateTotals();
    };

    function updateTotals() {
        var toplam = 0;
        var qTotals = [0, 0, 0, 0];
        for (var ay = 1; ay <= 12; ay++) {
            var val = parseFloat(document.getElementById('hedef-' + ay).value.replace(/\./g, '').replace(',', '.')) || 0;
            toplam += val;
            qTotals[Math.floor((ay - 1) / 3)] += val;
        }
        document.getElementById('yillikToplam').textContent = '₺' + fmtN.format(toplam) + 'M';
        for (var q = 0; q < 4; q++) {
            document.getElementById('q' + (q + 1) + '-toplam').textContent = '₺' + fmtN.format(qTotals[q]) + 'M';
        }
    }

    // Kaydet
    window.saveHedefler = async function() {
        var btn = document.getElementById('btnSave');
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Kaydediliyor...';

        var hedefler = [];
        for (var ay = 1; ay <= 12; ay++) {
            var val = parseFloat(document.getElementById('hedef-' + ay).value.replace(/\./g, '').replace(',', '.')) || 0;
            hedefler.push({ yil: yil, ay: ay, hedefTutar: val * 1000000 });
        }

        try {
            var res = await fetch('/Parametre/SaveHedefler', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ hedefler: hedefler })
            });
            var d = await res.json();
            if (d.success) {
                btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Kaydedildi';
                btn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
                btn.classList.add('bg-green-600');
                dirty = false;
                setTimeout(function(){
                    btn.innerHTML = '<i class="bi bi-check2-circle"></i> Kaydet';
                    btn.classList.remove('bg-green-600');
                    btn.classList.add('bg-blue-600', 'hover:bg-blue-700');
                    btn.disabled = true;
                }, 2000);
            } else {
                throw d.error || 'Hata';
            }
        } catch(e) {
            btn.innerHTML = '<i class="bi bi-x-circle"></i> Hata!';
            btn.classList.remove('bg-blue-600');
            btn.classList.add('bg-red-600');
            setTimeout(function(){
                btn.innerHTML = '<i class="bi bi-check2-circle"></i> Kaydet';
                btn.classList.remove('bg-red-600');
                btn.classList.add('bg-blue-600', 'hover:bg-blue-700');
                btn.disabled = false;
            }, 2000);
        }
    };

    // Unsaved changes warning
    window.addEventListener('beforeunload', function(e) {
        if (dirty) { e.preventDefault(); e.returnValue = ''; }
    });

})();
</script>
}
