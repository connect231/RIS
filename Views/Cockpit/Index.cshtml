    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    const fmt=new Intl.NumberFormat('tr-TR',{style:'currency',currency:'TRY',maximumFractionDigits:0});
    const fmtN=new Intl.NumberFormat('tr-TR',{maximumFractionDigits:0});
    let drillLoaded={};
    const charts={};
    const kalemLoaded={};

    async function showKalem(faturaNo, btn) {
        // Find the kalem-row for this fatura
        const rows = document.querySelectorAll('tr.kalem-row[data-fatura="'+faturaNo+'"]');
        if (!rows.length) return;
        const row = rows[rows.length-1]; // closest to button context
        // Find correct row: traverse from button
        const parentRow = btn.closest('tr');
        const kalemRow = parentRow.nextElementSibling;
        if (!kalemRow || !kalemRow.classList.contains('kalem-row')) return;

        // Toggle
        if (!kalemRow.classList.contains('hidden')) {
            kalemRow.classList.add('hidden');
            return;
        }
        kalemRow.classList.remove('hidden');

        const content = kalemRow.querySelector('.kalem-content');
        if (kalemLoaded[faturaNo]) return;

        content.innerHTML = '<div class="py-3"><div class="shimmer h-4 w-full mb-2"></div><div class="shimmer h-4 w-3/4"></div></div>';

        try {
            const res = await fetch('/Cockpit/GetKalemDetay?faturaNo='+encodeURIComponent(faturaNo));
            if (!res.ok) throw 0;
            const data = await res.json();

            if (!data || !data.length) {
                content.innerHTML = '<p class="text-[10px] text-slate-400 py-2">Kalem bulunamadı</p>';
                kalemLoaded[faturaNo] = true;
                return;
            }

            let h = '<table class="w-full text-[10px] my-2"><thead><tr class="text-slate-400"><th class="text-left py-1 px-2 font-medium">Ürün</th><th class="text-left py-1 px-2 font-medium">Stok kodu</th><th class="text-center py-1 px-2 font-medium">Miktar</th><th class="text-right py-1 px-2 font-medium">Birim fiyat</th><th class="text-right py-1 px-2 font-medium">KDV</th><th class="text-right py-1 px-2 font-medium">Toplam</th></tr></thead><tbody>';
            data.forEach(d => {
                h += '<tr class="border-t border-blue-50/50"><td class="py-1.5 px-2 text-slate-600 max-w-[180px] truncate">'+(d.urunAdi||'—')+'</td><td class="py-1.5 px-2 text-slate-400">'+(d.stokKodu||'—')+'</td><td class="py-1.5 px-2 text-center text-slate-500">'+fmtN.format(d.miktar||0)+'</td><td class="py-1.5 px-2 text-right text-slate-600">'+fmt.format(d.birimFiyat||0)+'</td><td class="py-1.5 px-2 text-right text-slate-400">'+fmt.format(d.kdv||0)+'</td><td class="py-1.5 px-2 text-right font-medium text-[#1e293b]">'+fmt.format(d.toplam||0)+'</td></tr>';
            });
            h += '</tbody></table>';
            content.innerHTML = h;
            kalemLoaded[faturaNo] = true;
        } catch {
            content.innerHTML = '<p class="text-[10px] text-red-400 py-2">Yüklenirken hata oluştu</p>';
        }
    }
    const activeFilter='@Model.AktifFiltre';
    const filterStart='@Model.FiltreBaslangic.ToString("yyyy-MM-dd")';
    const filterEnd='@Model.FiltreBitis.ToString("yyyy-MM-dd")';

    function applyRange() {
        const s=document.getElementById('rangeStart').value;
        const e=document.getElementById('rangeEnd').value;
        if(s&&e) window.location.href='/Cockpit/Index?startDate='+s+'&endDate='+e;
    }

    function grad(ctx,c1,c2){const g=ctx.createLinearGradient(0,0,0,240);g.addColorStop(0,c1);g.addColorStop(1,c2);return g;}
    const cMap={faturalar:{from:'rgba(29,78,216,0.6)',to:'rgba(29,78,216,0.08)',border:'#1d4ed8',hover:'rgba(29,78,216,0.75)'},tahsilatlar:{from:'rgba(245,158,11,0.55)',to:'rgba(245,158,11,0.08)',border:'#f59e0b',hover:'rgba(245,158,11,0.7)'},sozlesmeler:{from:'rgba(2,132,199,0.55)',to:'rgba(2,132,199,0.08)',border:'#0284c7',hover:'rgba(2,132,199,0.7)'}};

    function fmtDate(s){const d=new Date(s);return String(d.getDate()).padStart(2,'0')+'.'+String(d.getMonth()+1).padStart(2,'0')+'.'+d.getFullYear();}
    function skel(id){document.getElementById(id).innerHTML='<div class="space-y-3 mt-4"><div class="shimmer h-5 w-full"></div><div class="shimmer h-5 w-4/5"></div><div class="shimmer h-5 w-11/12"></div><div class="shimmer h-5 w-3/5"></div></div>';}

    let activeDetail=null;
    const detailMap={faturalar:'detail-faturalar',tahsilatlar:'detail-tahsilatlar',sozlesmeler:'detail-sozlesmeler'};

    function toggleDrill(t){if(activeDetail===t){closeAll(t);activeDetail=null;}else{if(activeDetail)closeAll(activeDetail);openAll(t);activeDetail=t;}}
    function closeAll(t){document.getElementById('drill-'+t).classList.remove('open');document.getElementById('arrow-'+t).classList.remove('rotated');if(detailMap[t])document.getElementById(detailMap[t]).classList.remove('open');}
    function openAll(t){document.getElementById('drill-'+t).classList.add('open');document.getElementById('arrow-'+t).classList.add('rotated');if(detailMap[t])document.getElementById(detailMap[t]).classList.add('open');if(!drillLoaded[t]){skel('data-'+t);load(t);}}

    // Close filter menu on outside click
    document.addEventListener('click',e=>{const m=document.getElementById('filterMenu');if(m&&!e.target.closest('.filter-dropdown'))m.classList.remove('show');});

    // Chart-only render (for default analytic row)
    async function renderChart(type){
        const cv=document.getElementById('chart-'+type);
        if(!cv)return;
        const wp=cv.parentElement;
        // Önceki "veri yok" mesajını temizle, canvas'ı göster
        const oldMsg=wp.querySelector('.no-data-msg');
        if(oldMsg)oldMsg.remove();
        cv.style.display='block';
        try{
            const url='/Cockpit/GetDailyBreakdown?type='+type+'&'+getDetayParams();
            const r=await fetch(url);if(!r.ok)throw 0;const data=await r.json();
            if(!data||!data.length){
                cv.style.display='none';
                if(charts[type]){charts[type].destroy();delete charts[type];}
                const msg=document.createElement('p');msg.className='no-data-msg text-[11px] text-slate-400 text-center py-8';msg.textContent='Bu dönemde veri bulunamadı.';wp.appendChild(msg);
                return;
            }

            const labels=data.map(d=>{const dt=new Date(d.tarih);return dt.getDate()+'.'+String(dt.getMonth()+1).padStart(2,'0');}),vals=data.map(d=>d.toplam),cnts=data.map(d=>d.adet),c=cMap[type],ctx=cv.getContext('2d');
            if(charts[type])charts[type].destroy();
            charts[type]=new Chart(cv,{type:'line',data:{labels,datasets:[{data:vals,fill:true,backgroundColor:grad(ctx,c.from,c.to),borderColor:c.border,borderWidth:2,pointBackgroundColor:c.border,pointRadius:3,pointHoverRadius:6,tension:0.4}]},
            options:{responsive:true,maintainAspectRatio:false,animation:{duration:800,easing:'easeOutQuart'},
                plugins:{legend:{display:false},tooltip:{backgroundColor:'rgba(30,27,75,0.92)',titleFont:{family:'Inter',size:12,weight:'600'},bodyFont:{family:'Inter',size:11},padding:12,cornerRadius:12,displayColors:false,
                    callbacks:{title:x=>fmtDate(data[x[0].dataIndex].tarih),label:x=>fmt.format(x.raw),afterLabel:x=>cnts[x.dataIndex]+' adet'}}},
                scales:{x:{grid:{display:false},border:{display:false},ticks:{font:{family:'Inter',size:8},color:'#94a3b8',padding:3,maxRotation:0}},
                    y:{grid:{color:'rgba(0,0,0,0.04)',drawBorder:false,borderDash:[3,3]},border:{display:false},ticks:{font:{family:'Inter',size:8},color:'#94a3b8',padding:4,callback:v=>v>=1e6?(v/1e6).toFixed(1)+'M':v>=1e3?(v/1e3).toFixed(0)+'K':v}}}}});
        }catch{wp.innerHTML='<p class="text-[11px] text-red-400 text-center py-4">Hata oluştu.</p>';}
    }

    // Drill-down table loader (no chart)
    async function load(type){
        const el=document.getElementById('data-'+type);
        if(!el){return;}
        // Sözleşmeler hala chart var
        const cv=document.getElementById('chart-'+type);
        if(cv && type==='sozlesmeler'){
            const wp=cv.parentElement;
            try{
                const url='/Cockpit/GetDailyBreakdown?type='+type+'&'+getDetayParams();
                const r=await fetch(url);if(!r.ok)throw 0;const data=await r.json();
                if(data&&data.length){
                    const labels=data.map(d=>{const dt=new Date(d.tarih);return dt.getDate()+'.'+String(dt.getMonth()+1).padStart(2,'0');}),vals=data.map(d=>d.toplam),cnts=data.map(d=>d.adet),c=cMap[type],ctx=cv.getContext('2d');
                    if(charts[type])charts[type].destroy();
                    charts[type]=new Chart(cv,{type:'line',data:{labels,datasets:[{data:vals,fill:true,backgroundColor:grad(ctx,c.from,c.to),borderColor:c.border,borderWidth:2,pointBackgroundColor:c.border,pointRadius:3,pointHoverRadius:6,tension:0.4}]},
                    options:{responsive:true,maintainAspectRatio:false,animation:{duration:800,easing:'easeOutQuart'},plugins:{legend:{display:false},tooltip:{backgroundColor:'rgba(30,27,75,0.92)',titleFont:{family:'Inter',size:12,weight:'600'},bodyFont:{family:'Inter',size:11},padding:12,cornerRadius:12,displayColors:false,callbacks:{title:x=>fmtDate(data[x[0].dataIndex].tarih),label:x=>fmt.format(x.raw),afterLabel:x=>cnts[x.dataIndex]+' adet'}}},scales:{x:{grid:{display:false},border:{display:false},ticks:{font:{family:'Inter',size:8},color:'#94a3b8',padding:3}},y:{grid:{color:'rgba(0,0,0,0.04)',drawBorder:false,borderDash:[3,3]},border:{display:false},ticks:{font:{family:'Inter',size:8},color:'#94a3b8',padding:4,callback:v=>v>=1e6?(v/1e6).toFixed(1)+'M':v>=1e3?(v/1e3).toFixed(0)+'K':v}}}}});
                }
            }catch{}
        }
        // Günlük tablo
        try{
            const url='/Cockpit/GetDailyBreakdown?type='+type+'&'+getDetayParams();
            const r=await fetch(url);if(!r.ok)throw 0;const data=await r.json();
            if(!data||!data.length){el.innerHTML='<p class="text-[11px] text-slate-400 text-center py-4">Veri bulunamadı.</p>';drillLoaded[type]=true;return;}
            let h='<div class="overflow-x-auto mt-3"><table class="w-full text-[11px]"><thead><tr class="border-b border-slate-100"><th class="text-left py-2 px-2 font-semibold text-slate-400">Tarih</th><th class="text-right py-2 px-2 font-semibold text-slate-400">Tutar</th><th class="text-right py-2 px-2 font-semibold text-slate-400">Adet</th></tr></thead><tbody>';
            data.forEach((d,i)=>{h+='<tr class="'+(i%2===0?'bg-slate-50/30':'')+' hover:bg-blue-50/20 transition-colors"><td class="py-1.5 px-2 text-slate-600">'+fmtDate(d.tarih)+'</td><td class="py-1.5 px-2 text-right font-semibold text-[#1e293b]">'+fmt.format(d.toplam)+'</td><td class="py-1.5 px-2 text-right text-slate-500">'+d.adet+'</td></tr>';});
            h+='</tbody></table></div>';el.innerHTML=h;drillLoaded[type]=true;
        }catch{el.innerHTML='<p class="text-[11px] text-red-400 text-center py-4">Hata oluştu.</p>';}
    }

    // Sayfa açıldığında default chart'ları yükle
    // Detay filtre (bağımsız)
    let detayFilter = 'month';
    function setDetayFilter(f, el) {
        detayFilter = f;
        // Tab aktif state
        document.querySelectorAll('.detay-tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        // Kalem cache temizle
        for (let k in kalemLoaded) delete kalemLoaded[k];
        // Açık detay panellerini kapat ve yeniden yükle
        const prev = activeDetail;
        if (prev) { closeAll(prev); activeDetail = null; }
        drillLoaded = {};
        // Debug: hangi filtre tetiklendi?
        console.log('Detay filtre değişti:', f);
        // Kartlar ve grafikler kesin güncellensin
        if(window.updateDetayCards) window.updateDetayCards(f);
        renderChart('faturalar');
        renderChart('tahsilatlar');
        // Eski açık paneli tekrar aç
        if (prev) { setTimeout(() => toggleDrill(prev), 150); }
    }

    // Override filter params for detay
    function getDetayParams() {
        const now = new Date();
        const y = now.getFullYear();
        const m = now.getMonth() + 1;
        switch(detayFilter) {
            case 'lastmonth': {
                const lm = m === 1 ? 12 : m - 1;
                const ly = m === 1 ? y - 1 : y;
                const ld = new Date(ly, lm, 0).getDate();
                return 'startDate=' + ly + '-' + String(lm).padStart(2,'0') + '-01&endDate=' + ly + '-' + String(lm).padStart(2,'0') + '-' + ld;
            }
            case 'q1': return 'startDate=' + y + '-01-01&endDate=' + y + '-03-31';
            case 'q2': return 'startDate=' + y + '-04-01&endDate=' + y + '-06-30';
            case 'q3': return 'startDate=' + y + '-07-01&endDate=' + y + '-09-30';
            case 'q4': return 'startDate=' + y + '-10-01&endDate=' + y + '-12-31';
            case 'ytd': return 'filter=ytd';
            default: return 'startDate=' + y + '-' + String(m).padStart(2,'0') + '-01&endDate=' + y + '-' + String(m).padStart(2,'0') + '-' + new Date(y, m, 0).getDate();
        }
    }

    document.addEventListener('DOMContentLoaded', function(){
        renderChart('faturalar');
        renderChart('tahsilatlar');
    });
</script>
}
