                        <td class="py-2 px-2 text-slate-500 text-center">@((t.Odeme_Sozu_Tarihi ?? t.Tahsil_Tarihi)?.ToString("dd.MM.yyyy") ?? "—")</td>
                        <td class="py-2 px-2 text-right font-semibold text-[#1e293b]">₺@((t.Fatura_Toplam ?? 0).ToString("N0"))</td>
                        <td class="py-2 px-2 text-center">
                            <button onclick="showKalem('@t.Fatura_No', this)" class="w-6 h-6 rounded-lg bg-slate-50 hover:bg-blue-100 flex items-center justify-center transition-all" title="Kalem detayı">
                                <i class="bi bi-eye text-slate-400 hover:text-blue-600" style="font-size:12px;"></i>
                            </button>
