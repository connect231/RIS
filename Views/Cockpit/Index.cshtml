@model SOS.Models.ViewModels.CockpitViewModel

@{
    ViewData["Title"] = "Cockpit";
    var pct = Model.HedefYuzde > 100 ? 100 : Model.HedefYuzde;
    var done = Model.HedefGerceklesme >= Model.AylikHedef;
    var filterLabel = Model.AktifFiltre switch {
        "ytd" => "YTD",
        "q1" => "Q1 (Oca-Nis)",
        "q2" => "Q2 (May-Ağu)",
        "q3" => "Q3 (Eyl-Ara)",
        "range" => "Manuel aralık",
        _ => "Bu ay"
    };
    var dateRange = Model.FiltreBaslangic.ToString("dd.MM.yyyy") + " — " + Model.FiltreBitis.ToString("dd.MM.yyyy");
    var headerDateRange = Model.FiltreBaslangic.ToString("dd.MM") + " – " + Model.FiltreBitis.ToString("dd.MM.yyyy");
}

<style>
    .card{background:white;border-radius:24px;border:1px solid rgba(0,0,0,0.05);box-shadow:0 2px 8px rgba(0,0,0,0.03);transition:all 0.3s ease-in-out;position:relative;overflow:hidden}
    .card:hover{box-shadow:0 8px 32px rgba(0,0,0,0.07);transform:translateY(-1px)}
    .accent-blue::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#2563eb,#3b82f6);border-radius:24px 24px 0 0}
    .accent-violet::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#7c3aed,#8b5cf6);border-radius:24px 24px 0 0}
    .accent-indigo::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#4f46e5,#6366f1);border-radius:24px 24px 0 0}
    .trend-up{color:#10b981}.trend-down{color:#ef4444}
    .target-container{background:white;border-radius:24px;border:1px solid rgba(0,0,0,0.05);box-shadow:0 4px 20px rgba(0,0,0,0.04);padding:32px}
    .target-divider{width:1px;background:rgba(0,0,0,0.06);align-self:stretch}
    .progress-track{height:10px;background:#f1f5f9;border-radius:99px;overflow:hidden}
    .progress-fill{height:100%;border-radius:99px;background:#8b5cf6;transition:width 1.5s cubic-bezier(0.25,0.46,0.45,0.94);box-shadow:0 0 12px rgba(139,92,246,0.3)}
    .drill-panel{background:rgba(255,255,255,0.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-radius:24px;border:1px solid rgba(0,0,0,0.05);overflow:hidden;max-height:0;opacity:0;transition:max-height 0.5s cubic-bezier(0.25,0.46,0.45,0.94),opacity 0.3s ease-in-out,margin 0.3s ease-in-out,padding 0.3s ease-in-out;margin-bottom:0;padding:0 28px}
    .drill-panel.open{max-height:800px;opacity:1;margin-bottom:24px;padding:28px}
    .shimmer{background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:8px}
    @@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
    .chevron-btn{transition:transform 0.3s ease-in-out}.chevron-btn.rotated{transform:rotate(180deg)}
    .detail-table thead th{position:sticky;top:0;background:white;z-index:5;box-shadow:0 1px 0 #e2e8f0}
    /* Filter dropdown */
    .filter-dropdown{position:relative}
    .filter-menu{position:absolute;top:100%;right:0;margin-top:8px;background:white;border-radius:16px;border:1px solid rgba(0,0,0,0.06);box-shadow:0 12px 40px rgba(0,0,0,0.1);padding:8px;min-width:220px;z-index:50;opacity:0;transform:translateY(-4px);pointer-events:none;transition:all 0.2s ease-in-out}
    .filter-menu.show{opacity:1;transform:translateY(0);pointer-events:auto}
    .filter-opt{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:10px;cursor:pointer;transition:all 0.15s ease;font-size:13px;color:#475569;text-decoration:none}
    .filter-opt:hover{background:#f1f5f9;color:#1e293b}
    .filter-opt.active{background:#ede9fe;color:#6d28d9;font-weight:600}
</style>

<!-- Header + Filter -->
<div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center">
            <i class="bi bi-bar-chart-line text-indigo-600 text-xl"></i>
        </div>
        <div>
            <h1 class="text-2xl font-semibold text-[#1e293b] tracking-tight">Finansal Cockpit <span class="text-base font-normal text-slate-400">| @headerDateRange</span></h1>
            <p class="text-xs text-slate-400 mt-0.5">Canlı veri &middot; @filterLabel</p>
        </div>
    </div>

    <!-- Filter: Range Picker + Presets -->
    <div class="filter-dropdown">
        <button onclick="document.getElementById('filterMenu').classList.toggle('show')" class="flex items-center gap-2 px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm font-medium text-[#1e293b] hover:border-indigo-300 transition-all">
            <i class="bi bi-calendar-range text-indigo-500"></i>
            @filterLabel
            <i class="bi bi-chevron-down text-slate-400 text-xs"></i>
        </button>
        <div id="filterMenu" class="filter-menu">
            <a href="@Url.Action("Index", "Cockpit", new { filter = "month" })" class="filter-opt @(Model.AktifFiltre == "month" ? "active" : "")">
                <i class="bi bi-calendar-day"></i> Bu ay
            </a>
            <a href="@Url.Action("Index", "Cockpit", new { filter = "ytd" })" class="filter-opt @(Model.AktifFiltre == "ytd" ? "active" : "")">
                <i class="bi bi-calendar-range"></i> YTD (yılbaşından bugüne)
            </a>
            <div class="h-px bg-slate-100 mx-2 my-1"></div>
            <a href="@Url.Action("Index", "Cockpit", new { filter = "q1" })" class="filter-opt @(Model.AktifFiltre == "q1" ? "active" : "")">
                <i class="bi bi-1-circle"></i> Q1 — Ocak › Nisan
            </a>
            <a href="@Url.Action("Index", "Cockpit", new { filter = "q2" })" class="filter-opt @(Model.AktifFiltre == "q2" ? "active" : "")">
                <i class="bi bi-2-circle"></i> Q2 — Mayıs › Ağustos
            </a>
            <a href="@Url.Action("Index", "Cockpit", new { filter = "q3" })" class="filter-opt @(Model.AktifFiltre == "q3" ? "active" : "")">
                <i class="bi bi-3-circle"></i> Q3 — Eylül › Aralık
            </a>
            <div class="px-3 pt-3 pb-1">
                <div class="h-px bg-slate-100 mb-3"></div>
                <label class="text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-2 block">Manuel aralık</label>
                <div class="flex items-center gap-2">
                    <input type="date" id="rangeStart" value="@Model.FiltreBaslangic.ToString("yyyy-MM-dd")"
                           class="flex-1 px-2.5 py-2 text-xs border border-slate-200 rounded-lg focus:outline-none focus:border-indigo-400 transition-colors" />
                    <span class="text-slate-300 text-xs">—</span>
                    <input type="date" id="rangeEnd" value="@Model.FiltreBitis.ToString("yyyy-MM-dd")"
                           class="flex-1 px-2.5 py-2 text-xs border border-slate-200 rounded-lg focus:outline-none focus:border-indigo-400 transition-colors" />
                </div>
                <button onclick="applyRange()" class="w-full mt-2 px-3 py-2 bg-indigo-500 hover:bg-indigo-600 text-white text-xs font-medium rounded-lg transition-colors">
                    Uygula
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ═══ UNIFIED TARGET CONTAINER ═══ -->
<div class="target-container mb-8">
    <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-0">
        <div class="flex-1">
            <p class="text-xs font-medium text-slate-400 tracking-wide mb-2">Gerçekleşen</p>
            <p class="text-[2.25rem] font-semibold text-[#1e293b] leading-none tracking-tight">₺@Model.HedefGerceklesme.ToString("N0")</p>
            <p class="text-sm text-slate-400 mt-2">@Model.FaturalarAdet fatura</p>
        </div>
        <div class="target-divider hidden md:block"></div>
        <div class="flex-1 md:px-8">
            <p class="text-xs font-medium text-slate-400 tracking-wide mb-2">Dönem hedefi <span class="text-violet-400">(@Model.HedefAySayisi ay &times; ₺45M = ₺@Model.AylikHedef.ToString("N0"))</span></p>
            <p class="text-[2.25rem] font-semibold text-indigo-500 leading-none tracking-tight">₺@Model.AylikHedef.ToString("N0")</p>
            <div class="mt-4">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-medium text-violet-500">%@Model.HedefYuzde.ToString("N0") tamamlandı</span>
                    <span class="text-xs text-slate-400">@Model.FiltreBaslangic.ToString("dd.MM.yyyy") — @Model.FiltreBitis.ToString("dd.MM.yyyy")</span>
                </div>
                <div class="progress-track">
                    <div class="progress-fill" style="width:@(pct)%"></div>
                </div>
            </div>
        </div>
        <div class="target-divider hidden md:block"></div>
        <div class="flex-1 md:pl-8">
            @if (done)
            {
                <p class="text-xs font-medium text-blue-400 tracking-wide mb-2">Durum</p>
                <p class="text-[2.25rem] font-semibold text-blue-600 leading-none tracking-tight flex items-center gap-3">
                    <i class="bi bi-check-circle-fill text-2xl"></i> Tamamlandı
                </p>
                <p class="text-sm text-blue-400 mt-2">Hedef başarıyla aşıldı</p>
            }
            else
            {
                <p class="text-xs font-medium text-violet-400 tracking-wide mb-2">Kalan fark</p>
                <p class="text-[2.25rem] font-semibold text-violet-600 leading-none tracking-tight">₺@Model.HedefKalan.ToString("N0")</p>
                <p class="text-sm text-violet-400 mt-2">Hedefe ulaşmak için gerekli tutar</p>
            }
        </div>
    </div>
</div>

<!-- ═══ SUMMARY CARDS ═══ -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
    <div class="card accent-blue p-6">
        <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-2xl bg-blue-50 flex items-center justify-center"><i class="bi bi-receipt text-blue-600 text-lg"></i></div>
            <button onclick="toggleDrill('faturalar')" class="w-8 h-8 rounded-xl bg-slate-50 hover:bg-blue-50 flex items-center justify-center transition-all group">
                <i class="bi bi-chevron-down text-slate-400 group-hover:text-blue-600 chevron-btn" id="arrow-faturalar"></i>
            </button>
        </div>
        <p class="text-xs font-medium text-slate-400 tracking-wide mb-1">Faturalar</p>
        <p class="text-[1.75rem] font-semibold text-[#1e293b] leading-tight">₺@Model.FaturalarToplam.ToString("N0")</p>
        <div class="flex items-center justify-between mt-3">
            <span class="text-xs text-slate-400">@Model.FaturalarAdet adet</span>
            @if (Model.FaturalarTrend != 0) { <span class="text-xs font-semibold flex items-center gap-1 @(Model.FaturalarTrend > 0 ? "trend-up" : "trend-down")"><i class="bi @(Model.FaturalarTrend > 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i> %@Math.Abs(Model.FaturalarTrend).ToString("N1")</span> }
            else { <span class="text-xs text-slate-300">—</span> }
        </div>
    </div>
    <div class="card accent-violet p-6">
        <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-2xl bg-violet-50 flex items-center justify-center"><i class="bi bi-cash-stack text-violet-600 text-lg"></i></div>
            <button onclick="toggleDrill('tahsilatlar')" class="w-8 h-8 rounded-xl bg-slate-50 hover:bg-violet-50 flex items-center justify-center transition-all group">
                <i class="bi bi-chevron-down text-slate-400 group-hover:text-violet-600 chevron-btn" id="arrow-tahsilatlar"></i>
            </button>
        </div>
        <p class="text-xs font-medium text-slate-400 tracking-wide mb-1">Tahsilatlar</p>
        <p class="text-[1.75rem] font-semibold text-[#1e293b] leading-tight">₺@Model.TahsilatlarToplam.ToString("N0")</p>
        <div class="flex items-center justify-between mt-3">
            <span class="text-xs text-slate-400">@Model.TahsilatlarAdet adet</span>
            @if (Model.TahsilatlarTrend != 0) { <span class="text-xs font-semibold flex items-center gap-1 @(Model.TahsilatlarTrend > 0 ? "trend-up" : "trend-down")"><i class="bi @(Model.TahsilatlarTrend > 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i> %@Math.Abs(Model.TahsilatlarTrend).ToString("N1")</span> }
            else { <span class="text-xs text-slate-300">—</span> }
        </div>
    </div>
    <div class="card accent-indigo p-6">
        <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-2xl bg-indigo-50 flex items-center justify-center"><i class="bi bi-file-earmark-check text-indigo-600 text-lg"></i></div>
            <button onclick="toggleDrill('sozlesmeler')" class="w-8 h-8 rounded-xl bg-slate-50 hover:bg-indigo-50 flex items-center justify-center transition-all group">
                <i class="bi bi-chevron-down text-slate-400 group-hover:text-indigo-600 chevron-btn" id="arrow-sozlesmeler"></i>
            </button>
        </div>
        <p class="text-xs font-medium text-slate-400 tracking-wide mb-1">Sözleşmeler</p>
        <p class="text-[1.75rem] font-semibold text-[#1e293b] leading-tight">₺@Model.SozlesmelerToplam.ToString("N0")</p>
        <div class="flex items-center justify-between mt-3">
            <span class="text-xs text-slate-400">@Model.SozlesmelerAdet adet &middot; Archived</span>
            <span class="text-xs text-slate-300">—</span>
        </div>
    </div>
</div>

<!-- ═══ DRILL-DOWN: Chart + Günlük Tablo ═══ -->
<div id="drill-faturalar" class="drill-panel">
    <div class="flex items-center justify-between mb-5">
        <h3 class="text-sm font-semibold text-[#1e293b] flex items-center gap-2"><i class="bi bi-receipt text-blue-600"></i> Faturalar — Günlük dağılım</h3>
        <span class="text-xs text-slate-400">@dateRange</span>
    </div>
    <div style="height:240px"><canvas id="chart-faturalar"></canvas></div>
    <div id="data-faturalar"></div>
</div>
<div id="drill-tahsilatlar" class="drill-panel">
    <div class="flex items-center justify-between mb-5">
        <h3 class="text-sm font-semibold text-[#1e293b] flex items-center gap-2"><i class="bi bi-cash-stack text-violet-600"></i> Tahsilatlar — Günlük dağılım</h3>
        <span class="text-xs text-slate-400">@dateRange</span>
    </div>
    <div style="height:240px"><canvas id="chart-tahsilatlar"></canvas></div>
    <div id="data-tahsilatlar"></div>
</div>
<div id="drill-sozlesmeler" class="drill-panel">
    <div class="flex items-center justify-between mb-5">
        <h3 class="text-sm font-semibold text-[#1e293b] flex items-center gap-2"><i class="bi bi-file-earmark-check text-indigo-600"></i> Sözleşmeler — Tarih bazlı dağılım</h3>
        <span class="text-xs text-slate-400">Archived</span>
    </div>
    <div style="height:240px"><canvas id="chart-sozlesmeler"></canvas></div>
    <div id="data-sozlesmeler"></div>
</div>

<!-- ═══ DETAIL TABLES (hidden, toggle with drill) ═══ -->
<div id="detail-faturalar" class="drill-panel">
    <h3 class="text-sm font-semibold text-[#1e293b] mb-4 flex items-center gap-2">
        <i class="bi bi-receipt text-blue-600"></i> Fatura detayları
        <span class="text-xs font-normal text-slate-400 ml-auto">@Model.FaturaDetaylari.Count kayıt</span>
    </h3>
    <div class="overflow-y-auto max-h-[360px] rounded-xl">
        <table class="w-full text-sm detail-table">
            <thead><tr>
                <th class="text-left py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[35%]">Fatura no</th>
                <th class="text-center py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[30%]">Tarih</th>
                <th class="text-right py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[35%]">Tutar</th>
            </tr></thead>
            <tbody>
                @foreach (var f in Model.FaturaDetaylari)
                {
                    <tr class="border-t border-slate-50 hover:bg-blue-50/20 transition-colors">
                        <td class="py-2.5 px-3 text-[#1e293b] font-medium text-xs">@f.Fatura_No</td>
                        <td class="py-2.5 px-3 text-slate-500 text-xs text-center">@(f.Fatura_Tarihi?.ToString("dd.MM.yyyy") ?? "—")</td>
                        <td class="py-2.5 px-3 text-right font-semibold text-[#1e293b] text-xs">₺@((f.Fatura_Toplam ?? 0).ToString("N0"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="detail-tahsilatlar" class="drill-panel">
    <h3 class="text-sm font-semibold text-[#1e293b] mb-4 flex items-center gap-2">
        <i class="bi bi-cash-stack text-violet-600"></i> Tahsilat detayları
        <span class="text-xs font-normal text-slate-400 ml-auto">@Model.TahsilatDetaylari.Count kayıt</span>
    </h3>
    <div class="overflow-y-auto max-h-[360px] rounded-xl">
        <table class="w-full text-sm detail-table">
            <thead><tr>
                <th class="text-left py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[35%]">Fatura no</th>
                <th class="text-center py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[30%]">Vade tarihi</th>
                <th class="text-right py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[35%]">Tutar</th>
            </tr></thead>
            <tbody>
                @foreach (var t in Model.TahsilatDetaylari)
                {
                    <tr class="border-t border-slate-50 hover:bg-violet-50/20 transition-colors">
                        <td class="py-2.5 px-3 text-[#1e293b] font-medium text-xs">@t.Fatura_No</td>
                        <td class="py-2.5 px-3 text-slate-500 text-xs text-center">@(t.Fatura_Vade_Tarihi?.ToString("dd.MM.yyyy") ?? "—")</td>
                        <td class="py-2.5 px-3 text-right font-semibold text-[#1e293b] text-xs">₺@((t.Fatura_Toplam ?? 0).ToString("N0"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="detail-sozlesmeler" class="drill-panel">
    <h3 class="text-sm font-semibold text-[#1e293b] mb-4 flex items-center gap-2">
        <i class="bi bi-file-earmark-check text-indigo-600"></i> Sözleşme detayları
        <span class="text-xs font-normal text-slate-400 ml-auto">@Model.SozlesmeDetaylari.Count kayıt</span>
    </h3>
    <div class="overflow-y-auto max-h-[360px] rounded-xl">
        <table class="w-full text-sm detail-table">
            <thead><tr>
                <th class="text-left py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[25%]">Sözleşme no</th>
                <th class="text-left py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[35%]">Müşteri</th>
                <th class="text-right py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[25%]">Tutar</th>
                <th class="text-center py-3 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[15%]">Durum</th>
            </tr></thead>
            <tbody>
                @foreach (var s in Model.SozlesmeDetaylari)
                {
                    <tr class="border-t border-slate-50 hover:bg-indigo-50/20 transition-colors">
                        <td class="py-2.5 px-3 text-[#1e293b] font-medium text-xs">@(s.ContractNo ?? "—")</td>
                        <td class="py-2.5 px-3 text-slate-500 text-xs truncate max-w-[200px]">@(s.AccountTitle ?? "—")</td>
                        <td class="py-2.5 px-3 text-right font-semibold text-[#1e293b] text-xs">₺@((s.TotalAmount ?? 0).ToString("N0"))</td>
                        <td class="py-2.5 px-3 text-center"><span class="inline-flex px-2 py-0.5 rounded-full bg-indigo-50 text-indigo-600 text-[10px] font-medium">@(s.ContractStatus ?? "—")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    const fmt=new Intl.NumberFormat('tr-TR',{style:'currency',currency:'TRY',maximumFractionDigits:0});
    const drillLoaded={},charts={};
    const activeFilter='@Model.AktifFiltre';
    const filterStart='@Model.FiltreBaslangic.ToString("yyyy-MM-dd")';
    const filterEnd='@Model.FiltreBitis.ToString("yyyy-MM-dd")';

    function applyRange() {
        const s=document.getElementById('rangeStart').value;
        const e=document.getElementById('rangeEnd').value;
        if(s&&e) window.location.href='/Cockpit/Index?startDate='+s+'&endDate='+e;
    }

    function grad(ctx,c1,c2){const g=ctx.createLinearGradient(0,0,0,240);g.addColorStop(0,c1);g.addColorStop(1,c2);return g;}
    const cMap={faturalar:{from:'rgba(37,99,235,0.35)',to:'rgba(37,99,235,0.03)',border:'#2563eb',hover:'rgba(37,99,235,0.5)'},tahsilatlar:{from:'rgba(124,58,237,0.35)',to:'rgba(124,58,237,0.03)',border:'#7c3aed',hover:'rgba(124,58,237,0.5)'},sozlesmeler:{from:'rgba(79,70,229,0.35)',to:'rgba(79,70,229,0.03)',border:'#4f46e5',hover:'rgba(79,70,229,0.5)'}};

    function fmtDate(s){const d=new Date(s);return String(d.getDate()).padStart(2,'0')+'.'+String(d.getMonth()+1).padStart(2,'0')+'.'+d.getFullYear();}
    function skel(id){document.getElementById(id).innerHTML='<div class="space-y-3 mt-4"><div class="shimmer h-5 w-full"></div><div class="shimmer h-5 w-4/5"></div><div class="shimmer h-5 w-11/12"></div><div class="shimmer h-5 w-3/5"></div></div>';}

    let activeDetail=null;
    const detailMap={faturalar:'detail-faturalar',tahsilatlar:'detail-tahsilatlar',sozlesmeler:'detail-sozlesmeler'};

    function toggleDrill(t){if(activeDetail===t){closeAll(t);activeDetail=null;}else{if(activeDetail)closeAll(activeDetail);openAll(t);activeDetail=t;}}
    function closeAll(t){document.getElementById('drill-'+t).classList.remove('open');document.getElementById('arrow-'+t).classList.remove('rotated');if(detailMap[t])document.getElementById(detailMap[t]).classList.remove('open');}
    function openAll(t){document.getElementById('drill-'+t).classList.add('open');document.getElementById('arrow-'+t).classList.add('rotated');if(detailMap[t])document.getElementById(detailMap[t]).classList.add('open');if(!drillLoaded[t]){skel('data-'+t);load(t);}}

    // Close filter menu on outside click
    document.addEventListener('click',e=>{const m=document.getElementById('filterMenu');if(m&&!e.target.closest('.filter-dropdown'))m.classList.remove('show');});

    async function load(type){
        const el=document.getElementById('data-'+type),cv=document.getElementById('chart-'+type),wp=cv.parentElement;
        try{
            const url='/Cockpit/GetDailyBreakdown?type='+type+'&filter='+activeFilter+'&startDate='+filterStart+'&endDate='+filterEnd;
            const r=await fetch(url);if(!r.ok)throw 0;const data=await r.json();
            if(!data||!data.length){wp.style.display='none';el.innerHTML='<p class="text-sm text-slate-400 text-center py-6">Veri bulunamadı.</p>';drillLoaded[type]=true;return;}

            const labels=data.map(d=>{const dt=new Date(d.tarih);return dt.getDate()+'.'+String(dt.getMonth()+1).padStart(2,'0');}),vals=data.map(d=>d.toplam),cnts=data.map(d=>d.adet),c=cMap[type],ctx=cv.getContext('2d');
            if(charts[type])charts[type].destroy();
            charts[type]=new Chart(cv,{type:'bar',data:{labels,datasets:[{data:vals,backgroundColor:grad(ctx,c.from,c.to),hoverBackgroundColor:c.hover,borderColor:c.border,borderWidth:1.5,borderRadius:10,borderSkipped:false,barPercentage:0.7,categoryPercentage:0.8}]},
            options:{responsive:true,maintainAspectRatio:false,animation:{duration:800,easing:'easeOutQuart'},
                plugins:{legend:{display:false},tooltip:{backgroundColor:'rgba(30,27,75,0.92)',titleFont:{family:'Inter',size:13,weight:'600'},bodyFont:{family:'Inter',size:12},padding:14,cornerRadius:14,displayColors:false,
                    callbacks:{title:x=>fmtDate(data[x[0].dataIndex].tarih),label:x=>fmt.format(x.raw),afterLabel:x=>cnts[x.dataIndex]+' adet'}}},
                scales:{x:{grid:{display:false},border:{display:false},ticks:{font:{family:'Inter',size:10,weight:'500'},color:'#94a3b8',padding:8}},
                    y:{grid:{color:'rgba(0,0,0,0.03)',drawBorder:false},border:{display:false},ticks:{font:{family:'Inter',size:10},color:'#94a3b8',padding:8,callback:v=>v>=1e6?(v/1e6).toFixed(1)+'M':v>=1e3?(v/1e3).toFixed(0)+'K':v}}}}});

            let h='<div class="overflow-x-auto mt-5"><table class="w-full text-sm"><thead><tr class="border-b border-slate-100"><th class="text-left py-2.5 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[35%]">Tarih</th><th class="text-right py-2.5 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[35%]">Tutar</th><th class="text-right py-2.5 px-3 text-xs font-semibold text-slate-400 tracking-wide w-[30%]">Adet</th></tr></thead><tbody>';
            data.forEach((d,i)=>{h+='<tr class="'+(i%2===0?'bg-slate-50/30':'')+' hover:bg-indigo-50/20 transition-colors"><td class="py-2.5 px-3 text-slate-600">'+fmtDate(d.tarih)+'</td><td class="py-2.5 px-3 text-right font-semibold text-[#1e293b]">'+fmt.format(d.toplam)+'</td><td class="py-2.5 px-3 text-right text-slate-500">'+d.adet+'</td></tr>';});
            h+='</tbody></table></div>';el.innerHTML=h;drillLoaded[type]=true;
        }catch{wp.style.display='none';el.innerHTML='<p class="text-sm text-red-400 text-center py-4"><i class="bi bi-exclamation-triangle me-1"></i> Hata oluştu.</p>';}
    }
</script>
}
