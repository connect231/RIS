<!-- ═══ DETAIL TABLES (hidden, toggle with drill) ═══ -->
<div id="detail-faturalar" class="drill-panel">
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-[#1e293b] flex items-center gap-2">
            <i class="bi bi-receipt text-blue-600"></i> Fatura detayları
        </h3>
        <div class="flex items-center gap-4">
            <span class="flex items-center gap-1.5 text-[10px] text-slate-400"><span class="inline-block w-2 h-2 rounded-full bg-green-400"></span> Satış</span>
            <span class="flex items-center gap-1.5 text-[10px] text-slate-400"><span class="inline-block w-2 h-2 rounded-full bg-amber-400"></span> İade</span>
            <span class="flex items-center gap-1.5 text-[10px] text-slate-400"><span class="inline-block w-2 h-2 rounded-full bg-red-400"></span> Ret</span>
            <span class="text-[10px] text-slate-400">@Model.FaturaDetaylari.Count kayıt</span>
        </div>
    </div>
    <div class="overflow-y-auto max-h-[420px] rounded-xl">
        <table class="w-full text-[11px] detail-table">
            <thead><tr>
                <th class="py-2.5 px-2 text-center" style="width:20px;"></th>
                <th class="text-left py-2.5 px-2 font-semibold text-slate-400">Fatura no</th>
                <th class="text-left py-2.5 px-2 font-semibold text-slate-400">Müşteri</th>
                <th class="text-center py-2.5 px-2 font-semibold text-slate-400">Tarih</th>
                <th class="text-right py-2.5 px-2 font-semibold text-slate-400">Tutar</th>
                <th class="text-right py-2.5 px-2 font-semibold text-slate-400">Kümülatif toplam</th>
                <th class="py-2.5 px-2 text-center" style="width:28px;"></th>
            </tr></thead>
            <tbody>
                @foreach (var f in Model.FaturaDetaylari)
                {
                    var dotColor = "bg-green-400";
                    var durumTrim = f.Durum?.Trim().ToUpper() ?? "";
                    if (durumTrim == "İADE" || durumTrim == "IADE") { dotColor = "bg-amber-400"; }
                    else if (durumTrim == "RET") { dotColor = "bg-red-400"; }
                    <tr class="border-t border-slate-50 hover:bg-blue-50/20 transition-colors">
                        <td class="py-2 px-2 text-center"><span class="inline-block w-2 h-2 rounded-full @dotColor"></span></td>
                        <td class="py-2 px-2 text-[#1e293b] font-medium">@f.Fatura_No</td>
                        <td class="py-2 px-2 text-slate-500 max-w-[140px] truncate" title="@(f.MusteriUnvan ?? "")">@(f.MusteriUnvan ?? "—")</td>
                        <td class="py-2 px-2 text-slate-500 text-center">@(f.Fatura_Tarihi?.ToString("dd.MM.yyyy") ?? "—")</td>
                        <td class="py-2 px-2 text-right font-semibold text-[#1e293b]">₺@((f.Fatura_Toplam ?? 0).ToString("N0"))</td>
                        <td class="py-2 px-2 text-right font-medium text-blue-600">₺@f.KumulatifToplam.ToString("N0")</td>
                        <td class="py-2 px-2 text-center">
                            <button onclick="showKalem('@f.Fatura_No', this)" class="w-6 h-6 rounded-lg bg-slate-50 hover:bg-blue-100 flex items-center justify-center transition-all" title="Kalem detayı">
                                <i class="bi bi-eye text-slate-400 hover:text-blue-600" style="font-size:12px;"></i>
                            </button>
                        </td>
                    </tr>
                    <tr class="kalem-row hidden border-t border-blue-50" data-fatura="@f.Fatura_No">
