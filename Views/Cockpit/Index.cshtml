@model SOS.Models.ViewModels.CockpitViewModel

@{
    ViewData["Title"] = "Cockpit";
    var pct = Model.HedefYuzde > 100 ? 100 : Model.HedefYuzde;
    var done = Model.HedefGerceklesme >= Model.AylikHedef;
    var filterLabel = Model.AktifFiltre switch {
        "ytd" => "YTD",
        "q1" => "Q1",
        "q2" => "Q2",
        "q3" => "Q3",
        "q4" => "Q4",
        "lastmonth" => "Geçen ay",
        "range" => "Manuel",
        _ => "Mevcut ay"
    };
    var tahsilatLabel = Model.AktifFiltre switch {
        "ytd" => "Yıllık tahsilat",
        "q1" => "Q1 tahsilat (Oca-Mar)",
        "q2" => "Q2 tahsilat (Nis-Haz)",
        "q3" => "Q3 tahsilat (Tem-Eyl)",
        "q4" => "Q4 tahsilat (Eki-Ara)",
        "lastmonth" => "Geçen ay tahsilat",
        "range" => "Dönemsel tahsilat",
        _ => "Aylık tahsilat"
    };
    var dateRange = Model.FiltreBaslangic.ToString("dd.MM.yyyy") + " — " + Model.FiltreBitis.ToString("dd.MM.yyyy");
    var headerDateRange = Model.FiltreBaslangic.ToString("dd.MM") + " – " + Model.FiltreBitis.ToString("dd.MM.yyyy");
}

<style>
    /* Floating card system */
    .card {
        background: white;
        border-radius: 16px;
        border: 1px solid rgba(30,58,138,0.06);
        box-shadow: 0 1px 3px rgba(30,58,138,0.04), 0 4px 12px rgba(30,58,138,0.03);
        transition: all 0.3s ease-in-out;
        position: relative;
        overflow: hidden;
    }
    .card:hover {
        box-shadow: 0 4px 16px rgba(30,58,138,0.08), 0 12px 40px rgba(30,58,138,0.06);
        transform: translateY(-2px);
    }

    /* Accent strips - Deep Blue (primary cards, unused now but kept) */
    .accent-blue::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#1d4ed8,#3b82f6); border-radius:16px 16px 0 0; }
    .accent-navy::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#1e3a8a,#1d4ed8); border-radius:16px 16px 0 0; }
    .accent-sky::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#0284c7,#0ea5e9); border-radius:16px 16px 0 0; }

    /* Detail card accents - Green & Yellow */
    .accent-emerald::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:#10b981; opacity:0.75; border-radius:16px 16px 0 0; }
    .accent-amber::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:#f59e0b; opacity:0.75; border-radius:16px 16px 0 0; }
    .accent-red::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:#ef4444; opacity:0.75; border-radius:16px 16px 0 0; }

    .trend-up { color:#10b981; }
    .trend-down { color:#ef4444; }

    /* PRIMARY: Target container — unified surface */
    .target-container {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #dbeafe;
        box-shadow: 0 4px 12px rgba(30,58,138,0.06), 0 12px 32px rgba(30,58,138,0.05);
        padding: 28px 32px;
    }

    /* SECONDARY: Summary cards — tinted background, lighter presence */
    .card-secondary {
        background: #f1f5f9;
        border-radius: 16px;
        border: 1px solid #cbd5e1;
        box-shadow: none;
        transition: all 0.3s ease-in-out;
        position: relative;
        overflow: hidden;
    }
    .card-secondary:hover {
        background: #e2e8f0;
        box-shadow: 0 4px 16px rgba(30,58,138,0.06);
        transform: translateY(-1px);
    }


    /* Progress bar */
    .progress-track { height:10px; background:#e0e7ff; border-radius:99px; overflow:hidden; }
    .progress-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,#1d4ed8,#3b82f6); transition:width 1.5s cubic-bezier(0.25,0.46,0.45,0.94); box-shadow:0 0 12px rgba(29,78,216,0.3); }

    /* Drill panels */
    .drill-panel {
        background: white;
        border-radius: 16px;
        border: 1px solid rgba(30,58,138,0.06);
        box-shadow: 0 1px 3px rgba(30,58,138,0.04);
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        transition: max-height 0.5s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.3s ease-in-out, margin 0.3s ease-in-out, padding 0.3s ease-in-out;
        margin-bottom: 0;
        padding: 0 28px;
    }
    .drill-panel.open { max-height:800px; opacity:1; margin-bottom:20px; padding:28px; }

    .shimmer { background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.5s infinite; border-radius:8px; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .chevron-btn { transition:transform 0.3s ease-in-out; }
    .chevron-btn.rotated { transform:rotate(180deg); }

    .detail-table thead th { position:sticky; top:0; background:white; z-index:5; box-shadow:0 1px 0 #e2e8f0; }

    /* Filter dropdown */
    .filter-dropdown { position:relative; }
    .filter-menu {
        position:absolute; top:100%; right:0; margin-top:8px;
        background:white; border-radius:14px;
        border:1px solid rgba(30,58,138,0.08);
        box-shadow:0 8px 32px rgba(30,58,138,0.12);
        padding:6px; min-width:200px; z-index:50;
        opacity:0; transform:translateY(-4px); pointer-events:none;
        transition:all 0.2s ease-in-out;
    }
    .filter-menu.show { opacity:1; transform:translateY(0); pointer-events:auto; }
    .filter-opt {
        display:flex; align-items:center; gap:8px;
        padding:9px 14px; border-radius:8px; cursor:pointer;
        transition:all 0.15s ease; font-size:13px; font-weight:500;
        color:#475569; text-decoration:none;
    }
    .filter-opt:hover { background:#eff6ff; color:#1e40af; }
    .filter-opt.active { background:#1e40af; color:white; font-weight:600; }
    /* Detay tab */
    .detay-tab { color:#94a3b8; transition:all 0.15s ease; cursor:pointer; text-decoration:none; }
    .detay-tab:hover { background:#f1f5f9; color:#1e293b; }
    .detay-tab.active { background:#1e40af; color:white; }
</style>


<!-- Header (sadece başlık) -->
<div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-lg bg-blue-100 flex items-center justify-center">
            <i class="bi bi-bar-chart-line text-blue-700" style="font-size:16px;"></i>
        </div>
        <div>
            <h1 class="text-xl font-semibold text-[#1e293b] tracking-tight">Finansal Cockpit</h1>
            <p class="text-[10px] text-slate-400">@headerDateRange &middot; Canlı veri</p>
        </div>
    </div>
</div>



<!-- ═══ UNIFIED DASHBOARD SURFACE ═══ -->
@{
    var beklenenLabel = Model.AktifFiltre switch {
        "q1" or "q2" or "q3" or "q4" => "Çeyrek kalanında beklenen",
        "ytd" => "Yıl kalanında beklenen",
        "lastmonth" => "—",
        "range" => "Dönem kalanında beklenen",
        _ => "Ayın kalanında beklenen"
    };
}
@{
    var ytdPct = Model.YtdYuzde > 100 ? 100 : Model.YtdYuzde;
}
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <!-- SOL: MEVCUT AY PERFORMANSI (İzole) -->
    <div class="target-container">
        <p class="text-[11px] font-bold text-blue-700 tracking-widest uppercase mb-3">MEVCUT AY PERFORMANSI</p>
        <div class="flex items-end gap-3 mb-1">
            <p class="text-[2rem] font-extrabold text-blue-600 leading-none tracking-tight">₺@Model.FixedCurrentMonthTarget.ToString("N0")</p>
            <span class="text-[10px] text-slate-400 mb-1">Nisan 2026 &times; ₺50M</span>
        </div>
        <div class="flex items-center justify-between mb-1.5 mt-3">
            <span class="text-[10px] font-semibold text-blue-600">%@Model.FixedCurrentMonthPct.ToString("N1") tamamlandı</span>
            <span class="text-[10px] text-slate-400">Kalan <span class="font-semibold text-blue-700">₺@((Model.FixedCurrentMonthTarget-Model.FixedCurrentMonthActual).ToString("N0"))</span></span>
        </div>
        <div class="progress-track">
            <div class="progress-fill" style="width:@(Model.FixedCurrentMonthPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%"></div>
        </div>
        <div class="flex items-center justify-between mt-3">
            <div>
                <p class="text-[9px] text-slate-400 uppercase tracking-wide">Gerçekleşen</p>
                <p class="text-lg font-bold text-[#1e293b] leading-none mt-0.5">₺@Model.FixedCurrentMonthActual.ToString("N0")</p>
            </div>
        </div>
        <p class="text-[8px] text-slate-400 mt-3 border-t border-slate-100 pt-2">01.04.2026 — 30.04.2026</p>
    </div>

    <!-- SAĞ: YILLIK (YTD) PERFORMANS (İzole) -->
    <div class="target-container">
        <p class="text-[11px] font-bold text-blue-700 tracking-widest uppercase mb-3">YILLIK (YTD) PERFORMANS</p>
        <div class="flex items-end gap-3 mb-1">
            <p class="text-[2rem] font-extrabold text-blue-600 leading-none tracking-tight">₺@Model.FixedYTDTarget.ToString("N0")</p>
            <span class="text-[10px] text-slate-400 mb-1">01.01.2026 — 01.04.2026 &times; ₺200M</span>
        </div>
        <div class="flex items-center justify-between mb-1.5 mt-3">
            <span class="text-[10px] font-semibold text-blue-600">%@Model.FixedYTDPct.ToString("N1") tamamlandı</span>
            <span class="text-[10px] text-slate-400">Kalan <span class="font-semibold text-blue-700">₺@((Model.FixedYTDTarget-Model.FixedYTDActual).ToString("N0"))</span></span>
        </div>
        <div class="progress-track">
            <div class="progress-fill" style="width:@(Model.FixedYTDPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%"></div>
        </div>
        <div class="flex items-center justify-between mt-3">
            <div>
                <p class="text-[9px] text-slate-400 uppercase tracking-wide">Gerçekleşen</p>
                <p class="text-lg font-bold text-[#1e293b] leading-none mt-0.5">₺@Model.FixedYTDActual.ToString("N0")</p>
            </div>
        </div>
        <p class="text-[8px] text-slate-400 mt-3 border-t border-slate-100 pt-2">01.01.2026 — 01.04.2026</p>
    </div>
</div>

<!-- Section divider + Detay filtresi -->
<div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-2">
        <div class="h-px w-8 bg-slate-200"></div>
        <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest">Detay kartları</span>
    </div>
    <div class="flex items-center gap-1" id="detayFiltre">
        <span class="text-[9px] text-slate-400 mr-1">Detay filtresi:</span>
        <a href="/Cockpit/Index" class="detay-tab @(Model.AktifFiltre=="month"?"active":"") px-2.5 py-1 rounded-md text-[10px] font-medium">Bu ay</a>
        <a href="/Cockpit/Index?filter=lastmonth" class="detay-tab @(Model.AktifFiltre=="lastmonth"?"active":"") px-2.5 py-1 rounded-md text-[10px] font-medium">Geçen ay</a>
        <a href="/Cockpit/Index?filter=q1" class="detay-tab @(Model.AktifFiltre=="q1"?"active":"") px-2.5 py-1 rounded-md text-[10px] font-medium">Q1</a>
        <a href="/Cockpit/Index?filter=q2" class="detay-tab @(Model.AktifFiltre=="q2"?"active":"") px-2.5 py-1 rounded-md text-[10px] font-medium">Q2</a>
        <a href="/Cockpit/Index?filter=q3" class="detay-tab @(Model.AktifFiltre=="q3"?"active":"") px-2.5 py-1 rounded-md text-[10px] font-medium">Q3</a>
        <a href="/Cockpit/Index?filter=q4" class="detay-tab @(Model.AktifFiltre=="q4"?"active":"") px-2.5 py-1 rounded-md text-[10px] font-medium">Q4</a>
        <a href="/Cockpit/Index?filter=ytd" class="detay-tab @(Model.AktifFiltre=="ytd"?"active":"") px-2.5 py-1 rounded-md text-[10px] font-medium">YTD</a>
    </div>
</div>

<!-- ═══ SUMMARY CARDS (Secondary layer) ═══ -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
    <div class="card-secondary accent-emerald p-4">
        <div class="flex items-start justify-between mb-4">
            <div class="w-9 h-9 rounded-xl bg-blue-100 flex items-center justify-center"><i class="bi bi-receipt text-blue-700 text-lg"></i></div>
            <button onclick="toggleDrill('faturalar')" class="w-8 h-8 rounded-xl bg-white/60 hover:bg-blue-100 flex items-center justify-center transition-all group">
                <i class="bi bi-chevron-down text-slate-400 group-hover:text-blue-700 chevron-btn" id="arrow-faturalar"></i>
            </button>
        </div>
        <p class="text-xs font-bold text-slate-500 tracking-wide mb-1 uppercase">Faturalar</p>
        <p id="faturalarTutar" class="text-[1.75rem] font-semibold text-[#1e293b] leading-tight">₺@Model.FaturalarToplam.ToString("N0")</p>
        <div class="flex items-center justify-between mt-3">
            <span id="faturalarAdet" class="text-xs text-slate-400">@Model.FaturalarAdet adet</span>
            @if (Model.FaturalarTrend != 0) { <span class="text-xs font-semibold flex items-center gap-1 @(Model.FaturalarTrend > 0 ? "trend-up" : "trend-down")"><i class="bi @(Model.FaturalarTrend > 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i> %@Math.Abs(Model.FaturalarTrend).ToString("N1")</span> }
            else { <span class="text-xs text-slate-300">—</span> }
        </div>
    </div>
    <div class="card-secondary accent-amber p-4">
        <div class="flex items-start justify-between mb-4">
            <div class="w-9 h-9 rounded-xl bg-indigo-100 flex items-center justify-center"><i class="bi bi-cash-stack text-indigo-700 text-lg"></i></div>
            <button onclick="toggleDrill('tahsilatlar')" class="w-8 h-8 rounded-xl bg-white/60 hover:bg-indigo-100 flex items-center justify-center transition-all group">
                <i class="bi bi-chevron-down text-slate-400 group-hover:text-indigo-700 chevron-btn" id="arrow-tahsilatlar"></i>
            </button>
        </div>
        <p class="text-xs font-bold text-slate-500 tracking-wide mb-1 uppercase">@tahsilatLabel</p>
        <div class="flex items-baseline gap-2">
            <p id="tahsilatlarTutar" class="text-[1.75rem] font-semibold text-[#1e293b] leading-tight">₺@Model.TahsilatlarToplam.ToString("N0")</p>
            <span class="text-xs text-slate-400">/ ₺@Model.TahsilEdilecek.ToString("N0")</span>
        </div>
        <div class="flex items-center justify-between mt-2">
            <span id="tahsilatlarAdet" class="text-xs text-slate-400">@Model.TahsilatlarAdet adet</span>
            @if (Model.TahsilKalan > 0)
            {
                <span class="text-[10px] text-blue-500 font-medium">Kalan: ₺@Model.TahsilKalan.ToString("N0")</span>
            }
            else
            {
                <span class="text-[10px] text-green-500 font-medium flex items-center gap-1"><i class="bi bi-check-circle-fill"></i> Hedef tamamlandı</span>
            }
        </div>
        <div class="flex items-center justify-between mt-1">
            <span class="text-xs text-slate-400"></span>
            @if (Model.TahsilatlarTrend != 0) { <span class="text-xs font-semibold flex items-center gap-1 @(Model.TahsilatlarTrend > 0 ? "trend-up" : "trend-down")"><i class="bi @(Model.TahsilatlarTrend > 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i> %@Math.Abs(Model.TahsilatlarTrend).ToString("N1")</span> }
            else { <span class="text-xs text-slate-300">—</span> }
        </div>
        <!-- Vadesi Geçmiş Alacak -->
        <div class="mt-3 pt-3 border-t border-slate-200/60">
            <div class="flex items-center justify-between">
                <span class="text-[10px] text-amber-600 font-semibold flex items-center gap-1"><i class="bi bi-exclamation-triangle-fill" style="font-size:10px;"></i> Vadesi geçmiş</span>
                <span class="text-[10px] text-slate-400">@Model.VadesiGecmisAdet fatura</span>
            </div>
            <p class="text-sm font-bold text-red-500 mt-1">₺@Model.VadesiGecmisAlacak.ToString("N2")</p>
            <p class="text-[9px] text-slate-400 mt-0.5">01.01.2025 — @Model.FiltreBaslangic.ToString("dd.MM.yyyy") arası açık bakiye</p>
        </div>
    </div>
    <div class="card-secondary accent-red p-4">
        <div class="flex items-start justify-between mb-4">
            <div class="w-9 h-9 rounded-xl bg-sky-100 flex items-center justify-center"><i class="bi bi-file-earmark-check text-sky-700 text-lg"></i></div>
            <button onclick="toggleDrill('sozlesmeler')" class="w-8 h-8 rounded-xl bg-white/60 hover:bg-sky-100 flex items-center justify-center transition-all group">
                <i class="bi bi-chevron-down text-slate-400 group-hover:text-sky-700 chevron-btn" id="arrow-sozlesmeler"></i>
            </button>
        </div>
        <p class="text-xs font-bold text-slate-500 tracking-wide mb-1 uppercase">Sözleşmeler</p>
        <p id="sozlesmelerTutar" class="text-[1.75rem] font-semibold text-[#1e293b] leading-tight">₺@Model.SozlesmelerToplam.ToString("N0")</p>
        <div class="flex items-center justify-between mt-3">
            <span id="sozlesmelerAdet" class="text-xs text-slate-400">@Model.SozlesmelerAdet adet &middot; Archived</span>
            <span class="text-xs text-slate-300">—</span>
        </div>
    </div>
</div>

<!-- ═══ ÜÇLÜ TAHSİLAT BAŞARI ANALİZİ ═══ -->
@{
    var ceiDPct = Model.CeiDonemOran > 100 ? 100 : Model.CeiDonemOran;
    var ceiAPct = Model.CeiAylikOran > 100 ? 100 : Model.CeiAylikOran;
    var ceiYPct = Model.CeiYillikOran > 100 ? 100 : Model.CeiYillikOran;
    string ceiDColor = Model.CeiDonemOran >= 80 ? "#10b981" : Model.CeiDonemOran >= 50 ? "#f59e0b" : "#ef4444";
    string ceiAColor = Model.CeiAylikOran >= 80 ? "#10b981" : Model.CeiAylikOran >= 50 ? "#f59e0b" : "#ef4444";
    string ceiYColor = Model.CeiYillikOran >= 80 ? "#10b981" : Model.CeiYillikOran >= 50 ? "#f59e0b" : "#ef4444";
}
<div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
    <!-- 1: Dönem Başarısı -->
    <div class="card p-3" style="background:rgba(255,255,255,0.7); backdrop-filter:blur(12px); border-top:3px solid @ceiDColor;">
        <div class="flex items-center justify-between mb-2">
            <span class="text-[9px] font-semibold text-slate-500 uppercase tracking-wide">Dönem başarısı</span>
            <span class="text-base font-bold" style="color:@ceiDColor;">%@Model.CeiDonemOran.ToString("N0")</span>
        </div>
        <div class="h-1.5 rounded-full overflow-hidden mb-2" style="background:rgba(0,0,0,0.04);">
            <div class="h-full rounded-full transition-all duration-1000" style="width:@(ceiDPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%; background:@ceiDColor;"></div>
        </div>
        <div class="text-[8px] text-slate-400">
            <span>₺@Model.CeiDonemTahsilat.ToString("N0") / ₺@((Model.CeiDonemTahsilat + Model.CeiDonemVadesiGecmis).ToString("N0"))</span>
        </div>
        <p class="text-[7px] text-slate-400 mt-0.5">@Model.FiltreBaslangic.ToString("dd.MM") → @Model.FiltreBitis.ToString("dd.MM.yyyy")</p>
    </div>

    <!-- 2: Aylık Başarı -->
    <div class="card p-3" style="background:rgba(255,255,255,0.7); backdrop-filter:blur(12px); border-top:3px solid @ceiAColor;">
        <div class="flex items-center justify-between mb-2">
            <span class="text-[9px] font-semibold text-slate-500 uppercase tracking-wide">Aylık başarı</span>
            <span class="text-base font-bold" style="color:@ceiAColor;">%@Model.CeiAylikOran.ToString("N0")</span>
        </div>
        <div class="h-1.5 rounded-full overflow-hidden mb-2" style="background:rgba(0,0,0,0.04);">
            <div class="h-full rounded-full transition-all duration-1000" style="width:@(ceiAPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%; background:@ceiAColor;"></div>
        </div>
        <div class="text-[8px] text-slate-400">
            <span>₺@Model.CeiAylikTahsilat.ToString("N0") / ₺@((Model.CeiAylikTahsilat + Model.CeiAylikVadesiGecmis).ToString("N0"))</span>
        </div>
        <p class="text-[7px] text-slate-400 mt-0.5">@DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</p>
    </div>

    <!-- 3: YTD Başarı -->
    <div class="card p-3" style="background:rgba(255,255,255,0.7); backdrop-filter:blur(12px); border-top:3px solid @ceiYColor;">
        <div class="flex items-center justify-between mb-2">
            <span class="text-[9px] font-semibold text-slate-500 uppercase tracking-wide">YTD başarı</span>
            <span class="text-base font-bold" style="color:@ceiYColor;">%@Model.CeiYillikOran.ToString("N0")</span>
        </div>
        <div class="h-1.5 rounded-full overflow-hidden mb-2" style="background:rgba(0,0,0,0.04);">
            <div class="h-full rounded-full transition-all duration-1000" style="width:@(ceiYPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%; background:@ceiYColor;"></div>
        </div>
        <div class="flex items-center justify-between text-[8px] text-slate-400">
            <span>₺@Model.CeiYillikTahsilat.ToString("N0") / ₺@((Model.CeiYillikTahsilat + Model.CeiYillikVadesiGecmis).ToString("N0"))</span>
            <span class="text-red-500 font-semibold">2025: ₺@Model.Legacy2025Bakiye.ToString("N0")</span>
        </div>
        <p class="text-[7px] text-slate-400 mt-0.5">01.01.2026 → @DateTime.Now.ToString("dd.MM.yyyy")</p>
    </div>
</div>

<!-- ═══ ANALİTİK SATIRI (Default Visible) ═══ -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
