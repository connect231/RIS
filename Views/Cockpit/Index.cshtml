                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="detail-sozlesmeler" class="drill-panel">
    <h3 class="text-sm font-semibold text-[#1e293b] mb-4 flex items-center gap-2">
        <i class="bi bi-file-earmark-check text-indigo-600"></i> Sözleşme detayları
        <span class="text-xs font-normal text-slate-400 ml-auto">@Model.SozlesmeDetaylari.Count kayıt</span>
