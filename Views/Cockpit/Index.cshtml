                @foreach (var s in Model.SozlesmeDetaylari)
                {
                    <tr class="border-t border-slate-50 hover:bg-indigo-50/20 transition-colors">
                        <td class="py-2.5 px-3 text-[#1e293b] font-medium text-xs">@(s.ContractNo ?? "—")</td>
                        <td class="py-2.5 px-3 text-slate-500 text-xs truncate max-w-[200px]">@(s.AccountTitle ?? "—")</td>
                        <td class="py-2.5 px-3 text-right font-semibold text-[#1e293b] text-xs">₺@((s.TotalAmount ?? 0).ToString("N0"))</td>
                        <td class="py-2.5 px-3 text-center"><span class="inline-flex px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 text-[10px] font-medium">@(s.ContractStatus ?? "—")</span></td>
                    </tr>
