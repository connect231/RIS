@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifremi Unuttum - Revenue Intelligence Systems</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

        .apple-input {
            background: #f5f5f7;
            border: none;
            border-radius: 12px;
            transition: all 0.2s ease;
        }
        .apple-input:focus {
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
            outline: none;
        }
        .apple-input::placeholder { color: #86868b; }

        .apple-btn {
            background: #1d1d1f;
            border-radius: 12px;
            transition: all 0.2s ease;
        }
        .apple-btn:hover { background: #000000; transform: scale(1.01); }
        .apple-btn:active { transform: scale(0.99); }
    </style>
</head>
<body class="h-full bg-white flex items-center justify-center overflow-hidden">

    <div class="w-full max-w-[400px] px-6">
        <!-- Icon -->
        <div class="text-center mb-8">
            <div class="w-14 h-14 bg-[#f5f5f7] rounded-2xl flex items-center justify-center mx-auto mb-6">
                <i class="bi bi-key text-2xl text-[#86868b]"></i>
            </div>
            <h2 class="text-2xl font-semibold text-[#1d1d1f] mb-2">Şifrenizi mi unuttunuz?</h2>
            <p class="text-sm text-[#86868b] font-light">E-posta adresinizi girin, size geçici bir şifre gönderelim.</p>
        </div>

        <!-- Form -->
        <form method="post" action="/Account/ForgotPassword" class="space-y-4">
            @if (TempData["Mesaj"] != null)
            {
                <div class="p-4 rounded-xl bg-indigo-50 text-indigo-700 text-sm flex items-center gap-3">
                    <i class="bi bi-info-circle"></i>
                    @TempData["Mesaj"]
                </div>
            }

            <input type="email" name="email" required
                   class="w-full px-4 py-3.5 apple-input text-[15px] text-[#1d1d1f]"
                   placeholder="E-posta" />

            <button type="submit"
                    class="w-full py-3.5 apple-btn text-white text-[15px] font-medium flex items-center justify-center gap-2">
                Şifre Gönder
            </button>
        </form>

        <!-- Back -->
        <div class="mt-8 text-center">
            <a href="/Account/Login" class="text-sm text-[#86868b] hover:text-[#1d1d1f] transition-colors flex items-center justify-center gap-2">
                <i class="bi bi-arrow-left"></i>
                Giriş ekranına dön
            </a>
        </div>
    </div>

</body>
</html>
