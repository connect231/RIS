@model SOS.Models.Kullanici.Account.AccountLoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Revenue Intelligence Systems</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

        .apple-input {
            background: #f5f5f7;
            border: none;
            border-radius: 12px;
            transition: all 0.2s ease;
        }
        .apple-input:focus {
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
            outline: none;
        }
        .apple-input::placeholder {
            color: #86868b;
        }

        .apple-btn {
            background: #1d1d1f;
            border-radius: 12px;
            transition: all 0.2s ease;
        }
        .apple-btn:hover {
            background: #000000;
            transform: scale(1.01);
        }
        .apple-btn:active {
            transform: scale(0.99);
        }

        @@keyframes fade-in {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fade-in 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
        }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }

        .hero-card {
            background: rgba(255,255,255,0.65);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.8);
            border-radius: 24px;
            transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                        box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                        border-color 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                        background 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            box-shadow: 0 4px 24px rgba(0,0,0,0.04);
            transform-style: preserve-3d;
            will-change: transform;
            position: relative;
            overflow: hidden;
        }
        .hero-card:hover {
            box-shadow: 0 20px 60px rgba(0,0,0,0.08);
            border-color: rgba(99, 102, 241, 0.3);
            background: rgba(255,255,255,0.85);
        }
        .hero-card-spotlight {
            position: absolute;
            inset: 0;
            border-radius: 24px;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.4s ease;
            z-index: 1;
        }
        .hero-card:hover .hero-card-spotlight {
            opacity: 1;
        }
        .hero-card > *:not(.hero-card-spotlight) {
            position: relative;
            z-index: 2;
        }
        .hero-card:hover .hero-title {
            letter-spacing: -0.01em;
        }
        .hero-card:hover .hero-accent {
            color: #4f46e5;
        }
        .hero-card:hover .hero-dot {
            transform: scale(1.5);
            box-shadow: 0 0 12px rgba(99, 102, 241, 0.4);
        }
        .hero-dot {
            transition: all 0.5s ease;
        }

        /* Animated background orbs */
        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 1;
            will-change: transform;
            pointer-events: none;
            z-index: 0;
        }
        .bg-orb-1 {
            width: 550px; height: 550px;
            background: radial-gradient(circle, rgba(99,102,241,0.55) 0%, rgba(99,102,241,0.15) 45%, transparent 70%);
            top: -15%; left: -10%;
            animation: orb-float-1 14s ease-in-out infinite;
        }
        .bg-orb-2 {
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.05) 45%, transparent 70%);
            bottom: -10%; right: -8%;
            animation: orb-float-2 18s ease-in-out infinite;
        }

        /* Floating grid dots */
        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(0,0,0,0.06) 1.2px, transparent 1.2px);
            background-size: 32px 32px;
            pointer-events: none;
            z-index: 0;
            mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 100%);
            -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 100%);
        }

        /* Floating particles */
        .bg-particle {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }
        .bg-particle:nth-child(4)  { width:5px; height:5px; background:rgba(99,102,241,0.5);  top:12%; left:20%; animation: particle-drift 8s ease-in-out infinite; }
        .bg-particle:nth-child(5)  { width:7px; height:7px; background:rgba(99,102,241,0.45); top:25%; left:65%; animation: particle-drift 11s ease-in-out infinite 0.5s; }
        .bg-particle:nth-child(6)  { width:4px; height:4px; background:rgba(99,102,241,0.55); top:40%; left:35%; animation: particle-drift 9s ease-in-out infinite 1.2s; }
        .bg-particle:nth-child(7)  { width:6px; height:6px; background:rgba(99,102,241,0.5);  top:55%; left:75%; animation: particle-drift 10s ease-in-out infinite 2s; }
        .bg-particle:nth-child(8)  { width:5px; height:5px; background:rgba(99,102,241,0.45); top:70%; left:15%; animation: particle-drift 12s ease-in-out infinite 0.8s; }
        .bg-particle:nth-child(9)  { width:8px; height:8px; background:rgba(99,102,241,0.4);  top:18%; left:45%; animation: particle-drift 7s ease-in-out infinite 3s; }
        .bg-particle:nth-child(10) { width:4px; height:4px; background:rgba(99,102,241,0.5);  top:80%; left:55%; animation: particle-drift 13s ease-in-out infinite 1.5s; }
        .bg-particle:nth-child(11) { width:6px; height:6px; background:rgba(99,102,241,0.5);  top:35%; left:85%; animation: particle-drift 9s ease-in-out infinite 2.5s; }
        .bg-particle:nth-child(12) { width:5px; height:5px; background:rgba(99,102,241,0.55); top:90%; left:40%; animation: particle-drift 8s ease-in-out infinite 0.3s; }
        .bg-particle:nth-child(13) { width:7px; height:7px; background:rgba(99,102,241,0.45); top:8%;  left:80%; animation: particle-drift 11s ease-in-out infinite 1.8s; }
        .bg-particle:nth-child(14) { width:4px; height:4px; background:rgba(99,102,241,0.5);  top:48%; left:10%; animation: particle-drift 10s ease-in-out infinite 3.5s; }
        .bg-particle:nth-child(15) { width:6px; height:6px; background:rgba(99,102,241,0.45); top:65%; left:50%; animation: particle-drift 14s ease-in-out infinite 0.7s; }
        .bg-particle:nth-child(16) { width:5px; height:5px; background:rgba(99,102,241,0.5);  top:30%; left:5%;  animation: particle-drift 9s ease-in-out infinite 2.2s; }
        .bg-particle:nth-child(17) { width:7px; height:7px; background:rgba(99,102,241,0.4);  top:75%; left:85%; animation: particle-drift 12s ease-in-out infinite 1s; }
        .bg-particle:nth-child(18) { width:5px; height:5px; background:rgba(99,102,241,0.55); top:5%;  left:50%; animation: particle-drift 8s ease-in-out infinite 4s; }

        @@keyframes orb-float-1 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(60px, 40px) scale(1.1); }
            50% { transform: translate(30px, 80px) scale(0.95); }
            75% { transform: translate(-20px, 30px) scale(1.05); }
        }
        @@keyframes orb-float-2 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(-50px, -30px) scale(1.08); }
            50% { transform: translate(-20px, -60px) scale(0.92); }
            75% { transform: translate(30px, -20px) scale(1.03); }
        }
        @@keyframes orb-float-3 {
            0%, 100% { transform: translate(-50%, -50%) scale(1); }
            33% { transform: translate(-40%, -60%) scale(1.15); }
            66% { transform: translate(-60%, -40%) scale(0.9); }
        }
        @@keyframes orb-float-4 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(-40px, 50px) scale(1.12); }
            50% { transform: translate(-70px, 20px) scale(0.9); }
            75% { transform: translate(-20px, -30px) scale(1.06); }
        }
        @@keyframes orb-float-5 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            30% { transform: translate(50px, -40px) scale(1.1); }
            60% { transform: translate(20px, 30px) scale(0.95); }
        }
        @@keyframes orb-float-6 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            20% { transform: translate(35px, 25px) scale(1.08); }
            50% { transform: translate(-25px, 50px) scale(0.93); }
            80% { transform: translate(15px, -20px) scale(1.05); }
        }
        @@keyframes particle-drift {
            0%, 100% { transform: translate(0, 0); opacity: 0.2; }
            25% { transform: translate(15px, -20px); opacity: 0.5; }
            50% { transform: translate(-10px, -35px); opacity: 0.3; }
            75% { transform: translate(20px, -15px); opacity: 0.6; }
        }
    </style>
</head>
<body class="h-full bg-white text-[#1d1d1f] overflow-hidden">

    <div class="h-full flex">

        <!-- LEFT: HERO -->
        <div class="hidden lg:flex lg:w-[58%] relative flex-col items-center justify-center overflow-hidden" style="background: #f5f5f7;">

            <!-- Dynamic background elements -->
            <div class="bg-orb bg-orb-1"></div>
            <div class="bg-orb bg-orb-2"></div>
            <div class="bg-grid"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>
            <div class="bg-particle"></div>

            <div class="w-full flex items-center justify-center px-12 animate-fade-in relative z-10">
                <div class="hero-card p-10 xl:p-12 cursor-default max-w-xl w-full text-center">
                    <h1 class="hero-title text-[2.75rem] xl:text-[3.25rem] font-bold text-[#1d1d1f] leading-[1.15] tracking-tight mb-6 transition-all duration-500">
                        Satış süreçlerinizi tek platformda <span class="text-indigo-600 hero-accent transition-colors duration-500">yönetin.</span>
                    </h1>

                    <p class="text-[17px] text-[#86868b] leading-relaxed font-light mx-auto max-w-md">
                        Teklif hazırlama, sözleşme takibi, müşteri talepleri ve finansal raporları tek bir merkezden kolayca yönetin.
                    </p>
                </div>
            </div>

            <!-- Bottom branding -->
            <div class="absolute bottom-10 left-0 right-0 px-20 xl:px-28">
                <span class="text-xs text-[#86868b]/40 tracking-widest font-medium">UNIVERA</span>
            </div>
        </div>

        <!-- RIGHT: LOGIN FORM -->
        <div class="w-full lg:w-[42%] flex flex-col justify-center px-8 sm:px-16 lg:px-16 bg-white">
            <div class="w-full max-w-[380px] mx-auto">

                <!-- Logo -->
                <div class="mb-12 animate-fade-in">
                    <div class="flex items-center gap-3 mb-1">
                        <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                            <rect width="36" height="36" rx="10" fill="#1d1d1f"/>
                            <text x="18" y="24" text-anchor="middle" fill="white" font-family="system-ui,-apple-system,sans-serif" font-size="20" font-weight="600">R</text>
                            <circle cx="27" cy="9" r="2.5" fill="#6366f1"/>
                        </svg>
                        <div>
                            <h1 class="text-xl font-semibold text-[#1d1d1f] leading-none">RIS</h1>
                            <p class="text-[11px] text-[#86868b] mt-0.5">Revenue Intelligence Systems</p>
                        </div>
                    </div>
                </div>

                <!-- Welcome text -->
                <div class="mb-8 animate-fade-in delay-1">
                    <h2 class="text-2xl font-semibold text-[#1d1d1f] mb-1">Hoş geldiniz.</h2>
                    <p class="text-sm text-[#86868b]">Devam etmek için giriş yapın.</p>
                </div>

                <!-- Form -->
                <form method="post" action="/Account/Login" class="animate-fade-in delay-2">
                    @if (TempData["Mesaj"] != null)
                    {
                        <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm flex items-center gap-3 mb-6">
                            <i class="bi bi-exclamation-circle"></i>
                            @TempData["Mesaj"]
                        </div>
                    }

                    <div class="space-y-3">
                        <input type="hidden" name="projectCode" id="project-code-hidden">

                        <input type="email" id="email" name="email" required
                               class="w-full px-4 py-3.5 apple-input text-[15px] text-[#1d1d1f]"
                               placeholder="E-posta" />

                        <div class="relative">
                            <input type="password" id="password" name="password" required
                                   class="w-full px-4 py-3.5 pr-12 apple-input text-[15px] text-[#1d1d1f]"
                                   placeholder="Şifre" />
                            <button type="button" id="togglePassword" class="absolute right-4 top-1/2 -translate-y-1/2 text-[#86868b] hover:text-[#1d1d1f] transition-colors focus:outline-none">
                                <i class="bi bi-eye text-lg"></i>
                            </button>
                        </div>
                    </div>

                    <div class="flex justify-end mt-3 mb-6">
                        <a href="/Account/ForgotPassword" class="text-sm text-indigo-600 hover:text-indigo-700 transition-colors font-medium">
                            Şifremi unuttum?
                        </a>
                    </div>

                    <button type="submit"
                            class="w-full py-3.5 apple-btn text-white text-[15px] font-medium flex items-center justify-center gap-2">
                        Giriş Yap
                    </button>
                </form>

                <!-- Footer -->
                <div class="mt-10 text-center animate-fade-in delay-3">
                    <p class="text-xs text-[#86868b]">
                        Hesabınız yok mu?
                        <a href="#" class="text-indigo-600 hover:text-indigo-700 transition-colors font-medium ml-1">Destek ile iletişime geçin</a>
                    </p>
                </div>
            </div>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loginForm = document.querySelector('form');
            const passwordInput = document.getElementById('password');
            let isAuthenticating = false;

            const togglePasswordBtn = document.getElementById('togglePassword');
            const toggleIcon = togglePasswordBtn?.querySelector('i');

            if (togglePasswordBtn && toggleIcon) {
                togglePasswordBtn.addEventListener('click', function () {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    toggleIcon.classList.toggle('bi-eye');
                    toggleIcon.classList.toggle('bi-eye-slash');
                });
            }

            loginForm.addEventListener('submit', async function(e) {
                if (loginForm.getAttribute('data-submitting') === 'true') return;
                e.preventDefault();
                if (isAuthenticating) return;
                isAuthenticating = true;

                const submitBtn = loginForm.querySelector('button[type="submit"]');
                submitBtn.innerHTML = '<span class="animate-spin inline-block w-4 h-4 border-2 border-white/30 border-t-white rounded-full mr-2"></span> Giriş yapılıyor...';
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.7';

                loginForm.setAttribute('data-submitting', 'true');
                loginForm.submit();
            });
        });
    </script>

    <!-- Loading Overlay -->
    <div id="login-loading-overlay" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(255,255,255,0.92); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); align-items:center; justify-content:center; flex-direction:column; gap:16px;">
        <div class="w-8 h-8 rounded-full border-[2.5px] border-gray-200 border-t-[#1d1d1f] animate-spin"></div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var overlay = document.getElementById('login-loading-overlay');
            var form = document.querySelector('form');
            if (!form || !overlay) return;
            var _origSubmit = HTMLFormElement.prototype.submit;
            form.submit = function () {
                overlay.style.display = 'flex';
                _origSubmit.call(this);
            };
        });
    </script>

    <!-- Hero Card 3D Tilt Effect -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const card = document.querySelector('.hero-card');
            if (!card) return;

            // Create spotlight overlay element
            const spotlight = document.createElement('div');
            spotlight.classList.add('hero-card-spotlight');
            card.prepend(spotlight);

            const MAX_ROTATION = 8; // degrees
            let rafId = null;
            let currentX = 0, currentY = 0;
            let targetX = 0, targetY = 0;

            function lerp(a, b, t) {
                return a + (b - a) * t;
            }

            function animate() {
                currentX = lerp(currentX, targetX, 0.08);
                currentY = lerp(currentY, targetY, 0.08);

                card.style.transform =
                    'perspective(800px) rotateX(' + currentY + 'deg) rotateY(' + currentX + 'deg)';

                if (Math.abs(currentX - targetX) > 0.01 || Math.abs(currentY - targetY) > 0.01) {
                    rafId = requestAnimationFrame(animate);
                } else {
                    currentX = targetX;
                    currentY = targetY;
                    card.style.transform =
                        'perspective(800px) rotateX(' + currentY + 'deg) rotateY(' + currentX + 'deg)';
                    rafId = null;
                }
            }

            function startAnimation() {
                if (!rafId) rafId = requestAnimationFrame(animate);
            }

            card.addEventListener('mousemove', function (e) {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;

                // Normalize to -1..1 range
                const normX = (x - centerX) / centerX;
                const normY = (y - centerY) / centerY;

                targetX = normX * MAX_ROTATION;
                targetY = -normY * MAX_ROTATION;

                // Update spotlight gradient to follow cursor
                spotlight.style.background =
                    'radial-gradient(circle 280px at ' + x + 'px ' + y + 'px, rgba(99,102,241,0.08) 0%, transparent 100%)';

                startAnimation();
            });

            card.addEventListener('mouseleave', function () {
                targetX = 0;
                targetY = 0;
                startAnimation();
            });
        });
    </script>
</body>
</html>
