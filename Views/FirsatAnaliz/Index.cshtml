    // Dönüşüm oranı helper — tutar bazlı, >100 gizle, 0/null → "—"
    function showConv(el, pay, payda, prefix) {
        if (!payda || payda <= 0 || !pay) { el.textContent = '\u2014'; el.classList.remove('hidden'); return; }
        var oran = pay / payda * 100;
        if (oran > 100) { el.classList.add('hidden'); return; }
        if (oran === 0) { el.textContent = '\u2014'; el.classList.remove('hidden'); return; }
        el.textContent = prefix + '%' + fmtPct.format(oran);
        el.classList.remove('hidden');
    }

    async function loadKpis() {
        try {
            var opp = await fetch('/FirsatAnaliz/GetOpportunitySummary?' + getFilterParams()).then(function(r) { return r.json(); });
            var lbl = donemLabel();

            // Update period labels
            document.getElementById('kpiLabel2').textContent = lbl + ' Fırsat';
            document.getElementById('kpiLabel3').textContent = lbl + ' Teklif';
            document.getElementById('kpiLabel4').textContent = lbl + ' Sipariş';
            document.getElementById('kpiLabel5').textContent = lbl + ' Satış Faturası';

            // Card 1: Tüm Fırsatlar — CountUp animasyonlu
            countUp(document.getElementById('kpiVal1'), opp.tumFirsatTutar, 1200);
            document.getElementById('kpiSub1').textContent = opp.tumFirsatAdet + ' fırsat · Açık havuz';
            // Sarı notu kaldır
            document.getElementById('kpiNote1').classList.add('hidden');

            // Card 1: Won + Lost info
            var lost1 = document.getElementById('kpiLost1');
            var totalExcluded1 = (opp.wonHavuzAdet || 0) + (opp.lostAdet || 0);
            if (totalExcluded1 > 0) {
                var parts1 = [];
                if (opp.wonHavuzAdet > 0) parts1.push(opp.wonHavuzAdet + ' kazanılan (' + abbr(opp.wonHavuzTutar) + ')');
                if (opp.lostAdet > 0) parts1.push(opp.lostAdet + ' kaybedilen (' + abbr(opp.lostTutar) + ')');
                document.getElementById('kpiLost1Text').innerHTML = '<i class="bi bi-exclamation-triangle-fill" style="font-size:11px;margin-right:4px;"></i>' + parts1.join(' + ') + ' hariç tutuldu';
                lost1.classList.remove('hidden');
            } else lost1.classList.add('hidden');

            // Card 2: Fırsat aşaması (exclusive — teklifi yok)
            countUp(document.getElementById('kpiVal2'), opp.exFirsatTutar, 1000);
            document.getElementById('kpiSub2a').textContent = opp.exFirsatAdet + ' fırsat · Henüz teklif verilmemiş';

            // Card 2: Footer — teklif aşamasına geçenler + kaybedilen
            var lost2 = document.getElementById('kpiLost2');
            var parts2 = [];
            if (opp.teklifeGecen > 0) parts2.push(opp.teklifeGecen + ' teklif aşamasına geçmiş');
            if (opp.donemLostAdet > 0) parts2.push(opp.donemLostAdet + ' kaybedilen hariç');
            if (parts2.length > 0) {
                document.getElementById('kpiLost2Text').innerHTML = '<i class="bi bi-info-circle-fill" style="font-size:11px;margin-right:4px;"></i>' + parts2.join(' · ');
                lost2.classList.remove('hidden');
            } else lost2.classList.add('hidden');

            // Card 3: Teklif aşaması (exclusive — siparişe dönüşmemiş)
            countUp(document.getElementById('kpiVal3'), opp.exTeklifTutar, 900);
            document.getElementById('kpiSub3').textContent = opp.exTeklifAdet + ' fırsat · Teklif aşamasında';

            // Card 3: Footer — siparişe dönüşen + reddedilen
            var lost3 = document.getElementById('kpiLost3');
            var parts3 = [];
            if (opp.sipariseGecen > 0) parts3.push(opp.sipariseGecen + ' siparişe dönüşmüş');
            if (opp.lostTeklifAdet > 0) parts3.push(opp.lostTeklifAdet + ' reddedilen hariç');
            if (parts3.length > 0) {
                document.getElementById('kpiLost3Text').innerHTML = '<i class="bi bi-info-circle-fill" style="font-size:11px;margin-right:4px;"></i>' + parts3.join(' · ');
                lost3.classList.remove('hidden');
            } else lost3.classList.add('hidden');

            // Card 4: Sipariş aşaması (exclusive — faturaya dönüşmemiş)
            countUp(document.getElementById('kpiVal4'), opp.exSiparisTutar, 800);
            document.getElementById('kpiSub4').textContent = opp.exSiparisAdet + ' fırsat · Sipariş aşamasında';

            // Card 4: Footer — faturaya dönüşen
            var lost4 = document.getElementById('kpiLost4');
            if (opp.faturayaGecen > 0) {
                document.getElementById('kpiLost4Text').innerHTML = '<i class="bi bi-info-circle-fill" style="font-size:11px;margin-right:4px;"></i>' + opp.faturayaGecen + ' faturaya dönüşmüş';
                lost4.classList.remove('hidden');
            } else lost4.classList.add('hidden');

            // Card 5: Fatura aşaması (exclusive fırsat adedi, SP fatura tutarı)
            countUp(document.getElementById('kpiVal5'), opp.kapaliSiparisTutar, 700);
            document.getElementById('kpiSub5').textContent = opp.exFaturaAdet + ' fırsat · Faturaya dönüştü';

            document.getElementById('kpiVal4').dataset.raw = opp.exSiparisTutar;
            window._oppData = opp;
            window._hedefTutar = opp.hedefTutar || 0;
            // Fatura verisi — exclusive fırsat adedi + SP fatura tutarı
            window._faturaData = { kapaliSiparisTutar: opp.kapaliSiparisTutar, kapaliSiparisAdet: opp.exFaturaAdet, gecenDonemFatura: opp.gecenDonemFatura };
            if (opp.hedefTutar > 0) updateHedefWithFatura(window._faturaData);

            // Kart 2-4 hedef renk kodları (fatura bağımsız)
            var hedef = opp.hedefTutar || 0;
            if (hedef > 0) {
                [
                    { idx: 2, val: opp.exFirsatTutar },
                    { idx: 3, val: opp.exTeklifTutar },
                    { idx: 4, val: opp.exSiparisTutar }
                ].forEach(function(k) {
                    var pct = (k.val / hedef) * 100;
                    var card = document.querySelector('[data-funnel="' + k.idx + '"]');
                    if (!card) return;
                    card.classList.remove('kpi-border-green','kpi-border-amber','kpi-border-red');
                    card.classList.add(pct >= 100 ? 'kpi-border-green' : pct >= 85 ? 'kpi-border-amber' : 'kpi-border-red');
                });

                // Dönem etiketi + hedef tutar (fatura bağımsız)
                document.getElementById('hedefDonemLabel').textContent = lbl + ' hedef analizi';
                document.getElementById('hedefHedefTutar').textContent = abbr(hedef);
            }

            // Aylık dağılım grafiği (fatura bağımsız)
            renderMonthlyChart(opp.aylikTrend || []);
            if (_funnelExpanded > 0) renderFunnelExpand();

            // Hedef paneli + potansiyel + geçen dönem → fatura verisi gelince render edilecek (updateHedefWithFatura)

        } catch (e) { console.error('KPI error:', e); }
    }

    // Fatura verisi gelince hedef panelinin tamamını render et
    function updateHedefWithFatura(f) {
        var opp = window._oppData;
        var hedef = window._hedefTutar;
        if (!opp || !hedef || hedef <= 0) return;

        var fatVal = f.kapaliSiparisTutar || 0;
        var faturaPct = (fatVal / hedef) * 100;

        function pctColor(v) { return v >= 100 ? 'text-emerald-600' : v >= 85 ? 'text-amber-600' : 'text-red-500'; }
        function safeHtml(id, html) { var el = document.getElementById(id); if (el) el.innerHTML = html; }

        // Kart 5 hedef renk
        var card5 = document.querySelector('[data-funnel="5"]');
        if (card5) {
            card5.classList.remove('kpi-border-green','kpi-border-amber','kpi-border-red');
            card5.classList.add(faturaPct >= 100 ? 'kpi-border-green' : faturaPct >= 85 ? 'kpi-border-amber' : 'kpi-border-red');
        }

        // Büyük yüzde + progress bar
        var el = document.getElementById('hedefPctBig');
        if (el) { el.textContent = '%' + fmtPct.format(faturaPct); el.style.color = faturaPct >= 100 ? '#22d3a0' : faturaPct >= 85 ? '#f59e0b' : '#f87171'; }
        var bar = document.getElementById('hedefBarBig');
        if (bar) {
            setTimeout(function() {
                bar.style.width = Math.min(faturaPct, 100) + '%';
                bar.style.background = faturaPct >= 100 ? '#22d3a0' : faturaPct >= 85 ? '#f59e0b' : '#f87171';
            }, 200);
        }
        var ge = document.getElementById('hedefGerceklesen');
        if (ge) ge.textContent = abbr(fatVal);

        // Geçen dönem karşılaştırma
        var gecenFat = f.gecenDonemFatura || 0;
        if (gecenFat > 0) {
            var gecenTutarEl = document.getElementById('gecenAyTutar');
            if (gecenTutarEl) gecenTutarEl.textContent = abbr(gecenFat);
            var trendEl = document.getElementById('gecenAyTrend');
            if (trendEl && fatVal > 0) {
                var trendPct = ((fatVal - gecenFat) / gecenFat * 100);
                trendEl.innerHTML = '<span class="' + (trendPct >= 0 ? 'text-emerald-600' : 'text-red-500') + '">' + (trendPct >= 0 ? '\u2191' : '\u2193') + ' %' + fmtPct.format(Math.abs(trendPct)) + '</span>';
            }
        }

        // Aşama detayları
        var fp = (opp.exFirsatTutar||0)/hedef*100, tp = (opp.exTeklifTutar||0)/hedef*100, sp = (opp.exSiparisTutar||0)/hedef*100;
        safeHtml('hedefFirsatPct', abbr(opp.exFirsatTutar||0) + ' <span class="' + pctColor(fp) + '">%' + fmtPct.format(fp) + '</span>');
        safeHtml('hedefTeklifPct', abbr(opp.exTeklifTutar||0) + ' <span class="' + pctColor(tp) + '">%' + fmtPct.format(tp) + '</span>');
        safeHtml('hedefSiparisPct', abbr(opp.exSiparisTutar||0) + ' <span class="' + pctColor(sp) + '">%' + fmtPct.format(sp) + '</span>');
        safeHtml('hedefFaturaPct', abbr(fatVal) + ' <span class="' + pctColor(faturaPct) + '">%' + fmtPct.format(faturaPct) + '</span>');

        // Huni chart
        renderHedefChart(hedef, opp);

        // Potansiyel analizi
        var potArea = document.getElementById('potansiyelArea');
        if (potArea) {
            var teklifPotansiyel = opp.agirlikliPotansiyel || 0;
            var acikSipTutar = opp.exSiparisTutar || 0; // Exclusive: sadece faturası olmayanlar
            var toplamPotansiyel = fatVal + acikSipTutar + teklifPotansiyel;
            var potPct = (toplamPotansiyel / hedef) * 100;
            var ortOlasilik = opp.ortOlasilik || 0;

            var teklifAdet = opp.exTeklifAdet || 0;
            var sipAdet = opp.exSiparisAdet || 0;
            var fatAdet = opp.kapaliSiparisAdet || 0;

            var ph = '';
            ph += '<div class="px-3 py-2.5 rounded-lg bg-violet-50/50 border border-violet-100">';
            ph += '<p class="text-[10px] font-bold text-violet-700">Teklif potansiyeli</p>';
            ph += '<p class="text-[18px] font-extrabold text-violet-700">' + abbr(teklifPotansiyel) + '</p>';
            ph += '<p class="text-[9px] text-violet-600">' + teklifAdet + ' aktif teklifin tutarı, fırsat olasılıklarıyla ağırlıklandırılmış</p>';
            ph += '<p class="text-[9px] text-violet-500 mt-0.5">Ortalama kazanma olasılığı: %' + fmtPct.format(ortOlasilik) + '</p>';
            ph += '</div>';
            var potClr = potPct >= 100 ? 'bg-emerald-50 border-emerald-200' : potPct >= 85 ? 'bg-amber-50 border-amber-200' : 'bg-red-50 border-red-200';
            var potTxtClr = potPct >= 100 ? 'text-emerald-700' : potPct >= 85 ? 'text-amber-700' : 'text-red-700';
            ph += '<div class="px-3 py-2.5 rounded-lg ' + potClr + ' border">';
            ph += '<p class="text-[10px] font-bold ' + pctColor(potPct) + '">Tahmini hedef gerçekleşme</p>';
            ph += '<p class="text-[22px] font-extrabold ' + pctColor(potPct) + '">%' + fmtPct.format(potPct) + '</p>';
            ph += '<div class="text-[9px] text-[#64748b] mt-1 space-y-0.5">';
            ph += '<p><span class="inline-block w-2 h-2 rounded-full bg-emerald-500 mr-1"></span><b>Faturalanan:</b> ' + abbr(fatVal) + ' <span class="text-[#94a3b8]">(' + fatAdet + ' fatura · kesinleşmiş gelir)</span></p>';
            ph += '<p><span class="inline-block w-2 h-2 rounded-full bg-cyan-500 mr-1"></span><b>Açık sipariş:</b> ' + abbr(acikSipTutar) + ' <span class="text-[#94a3b8]">(' + sipAdet + ' sipariş · fatura bekliyor)</span></p>';
            ph += '<p><span class="inline-block w-2 h-2 rounded-full bg-violet-500 mr-1"></span><b>Teklif potansiyeli:</b> ' + abbr(teklifPotansiyel) + ' <span class="text-[#94a3b8]">(olasılık ağırlıklı)</span></p>';
            ph += '</div>';
            ph += '<p class="text-[9px] text-[#64748b] mt-1 pt-1 border-t border-[#e2e8f0]"><b>Toplam:</b> ' + abbr(toplamPotansiyel) + ' / ' + abbr(hedef) + ' hedef</p>';
            ph += '</div>';
            potArea.innerHTML = ph;
        }
    }

    /* ══════════════════════════════════
       PARETO CHART (Ürün Bazlı)
       ══════════════════════════════════ */
    var paretoInstance = null;
    function renderParetoChart(items) {
        var cv = document.getElementById('paretoChart');
        if (!cv) return;
        if (paretoInstance) paretoInstance.destroy();

        if (!items || !items.length) {
            cv.parentElement.innerHTML = '<p class="text-[11px] text-[#94a3b8] text-center py-8">Veri Bulunamadı</p>';
            return;
        }

        // Kümülatif % hesapla
        var toplam = items.reduce(function(s, p) { return s + p.tutar; }, 0) || 1;
        var kumulatif = 0;
        var cumPcts = items.map(function(p) { kumulatif += p.tutar; return Math.round(kumulatif / toplam * 100); });

        // %80 eşik çizgisi için index bul
        var esikIdx = cumPcts.findIndex(function(c) { return c >= 80; });

        // Bar renkleri — %80 altı yeşil, üstü soluk
        var barColors = items.map(function(p, i) {
            return cumPcts[i] <= 80 || i === esikIdx ? '#10b981' : '#cbd5e1';
        });

        paretoInstance = new Chart(cv, {
            type: 'bar',
            data: {
                labels: items.map(function(p) { return p.urun; }),
                datasets: [{
                    type: 'bar',
                    data: items.map(function(p) { return p.tutar; }),
                    backgroundColor: barColors,
                    borderRadius: 4,
                    barThickness: 28,
                    yAxisID: 'y',
                    order: 2
                }, {
                    type: 'line',
                    data: cumPcts,
                    borderColor: '#6366f1',
                    borderWidth: 2,
                    pointBackgroundColor: '#6366f1',
                    pointRadius: 3,
                    pointHoverRadius: 5,
                    tension: 0.3,
                    fill: false,
                    yAxisID: 'y1',
                    order: 1
                }]
            },
            plugins: [{
                id: 'paretoLine80',
                afterDraw: function(chart) {
                    var y1 = chart.scales.y1;
                    if (!y1) return;
                    var yPos = y1.getPixelForValue(80);
                    var ctx = chart.ctx;
                    ctx.save();
                    ctx.strokeStyle = '#f87171';
                    ctx.lineWidth = 1;
                    ctx.setLineDash([4, 3]);
                    ctx.beginPath();
                    ctx.moveTo(chart.chartArea.left, yPos);
                    ctx.lineTo(chart.chartArea.right, yPos);
                    ctx.stroke();
                    // Label
                    ctx.fillStyle = '#f87171';
                    ctx.font = '600 9px DM Sans';
                    ctx.textAlign = 'right';
                    ctx.fillText('%80 eşik', chart.chartArea.right, yPos - 4);
                    ctx.restore();
                }
            }],
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: { duration: 600 },
                onClick: function(evt, elements) {
                    if (elements.length > 0 && elements[0].datasetIndex === 0) {
                        var idx = elements[0].index;
                        window._filterByProduct(encodeURIComponent(items[idx].urun));
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.9)',
                        titleFont: { family: 'DM Sans', size: 11 },
                        bodyFont: { family: 'DM Sans', size: 11 },
                        padding: 10, cornerRadius: 8,
                        callbacks: {
                            label: function(ctx) {
                                if (ctx.datasetIndex === 0) return abbr(ctx.raw);
                                return 'Kümülatif: %' + ctx.raw;
                            }
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { family: 'DM Sans', size: 9 }, color: '#64748b', maxRotation: 45 } },
                    y: {
                        position: 'left',
                        grid: { color: 'rgba(0,0,0,0.03)', borderDash: [2,2] },
                        border: { display: false },
                        ticks: { font: { family: 'DM Sans', size: 9 }, color: '#94a3b8',
                            callback: function(v) { return v >= 1e6 ? (v/1e6).toFixed(0) + 'M' : v >= 1e3 ? (v/1e3).toFixed(0) + 'K' : v; }
                        }
                    },
                    y1: {
                        position: 'right',
                        min: 0, max: 100,
                        grid: { display: false },
                        border: { display: false },
                        ticks: { font: { family: 'DM Sans', size: 9 }, color: '#a5b4fc',
                            callback: function(v) { return '%' + v; },
                            stepSize: 20
                        }
                    }
                }
            }
        });
    }

    /* ══════════════════════════════════
       HEDEF CHART
       ══════════════════════════════════ */
    // Hedef çizgisi plugin (annotation plugin gerekmez)
    var _hedefLineValue = 0;
    var hedefLinePlugin = {
        id: 'hedefLine',
        afterDraw: function(chart) {
            var hedefVal = _hedefLineValue;
            if (!hedefVal || hedefVal <= 0) return;
            var yScale = chart.scales.y;
            var y = yScale.getPixelForValue(hedefVal);
            // Hedef çizgisi her zaman görünmeli — chart alanı dışına taşsa bile clamp et
            if (y > yScale.bottom) return; // hedef 0'ın altındaysa çizme
            if (y < yScale.top) y = yScale.top + 2; // üstten taşıyorsa en üste çiz
            var ctx = chart.ctx;
            ctx.save();
            ctx.beginPath();
            ctx.setLineDash([5, 3]);
            ctx.strokeStyle = '#ef4444';
            ctx.lineWidth = 1.5;
            ctx.moveTo(chart.chartArea.left, y);
            ctx.lineTo(chart.chartArea.right, y);
            ctx.stroke();
            // Label
            ctx.fillStyle = '#ef4444';
            ctx.font = '600 9px DM Sans, sans-serif';
            ctx.textAlign = 'right';
            ctx.fillText('Hedef: ' + (hedefVal >= 1e6 ? (hedefVal/1e6).toFixed(0)+'M' : hedefVal >= 1e3 ? (hedefVal/1e3).toFixed(0)+'K' : hedefVal), chart.chartArea.right, y - 4);
            ctx.restore();
        }
    };

    // ── Aylık Dağılım Grafiği (Chart.js smooth area) ──
    var monthlyChartInstance = null;
    function renderMonthlyChart(data) {
        var canvas = document.getElementById('monthlyChartCanvas');
        if (!canvas) return;
        if (monthlyChartInstance) { monthlyChartInstance.destroy(); monthlyChartInstance = null; }
        if (!data || !data.length) return;

        var ayMap = { '01':'Oca','02':'Şub','03':'Mar','04':'Nis','05':'May','06':'Haz','07':'Tem','08':'Ağu','09':'Eyl','10':'Eki','11':'Kas','12':'Ara' };
        var labels = data.map(function(d) { var p = d.ay.split('-'); return ayMap[p[1]] || p[1]; });

        var ctx = canvas.getContext('2d');

        // Gradient fills
        var gFirsat = ctx.createLinearGradient(0, 0, 0, 280);
        gFirsat.addColorStop(0, 'rgba(139,92,246,0.35)');
        gFirsat.addColorStop(1, 'rgba(139,92,246,0.02)');
        var gTeklif = ctx.createLinearGradient(0, 0, 0, 280);
        gTeklif.addColorStop(0, 'rgba(59,130,246,0.3)');
        gTeklif.addColorStop(1, 'rgba(59,130,246,0.02)');
        var gKapali = ctx.createLinearGradient(0, 0, 0, 280);
        gKapali.addColorStop(0, 'rgba(16,185,129,0.3)');
        gKapali.addColorStop(1, 'rgba(16,185,129,0.02)');

        monthlyChartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Fırsat Tutarı',
                        data: data.map(function(d) { return d.firsatTutar; }),
                        borderColor: '#8b5cf6',
                        backgroundColor: gFirsat,
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#8b5cf6',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 6
                    },
                    {
                        label: 'Teklif Tutarı',
                        data: data.map(function(d) { return d.teklifTutar; }),
                        borderColor: '#3b82f6',
                        backgroundColor: gTeklif,
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#3b82f6',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 6
                    },
                    {
                        label: 'Açık Sipariş',
                        data: data.map(function(d) { return d.acikSiparisTutar; }),
                        borderColor: '#f59e0b',
                        backgroundColor: 'rgba(245,158,11,0.08)',
                        borderWidth: 2,
                        borderDash: [4, 3],
                        fill: false,
                        tension: 0.4,
                        pointRadius: 3,
                        pointBackgroundColor: '#f59e0b',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 5
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'top',
                        labels: {
                            usePointStyle: true,
                            pointStyle: 'circle',
                            padding: 16,
                            font: { family: "'DM Sans', sans-serif", size: 11, weight: '500' },
                            color: '#64748b'
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.9)',
                        titleFont: { family: "'DM Sans', sans-serif", size: 12, weight: '600' },
                        bodyFont: { family: "'DM Sans', sans-serif", size: 11 },
                        padding: 12,
                        cornerRadius: 10,
                        callbacks: {
                            label: function(ctx) {
                                var val = ctx.parsed.y || 0;
                                var label = ctx.dataset.label || '';
                                if (val >= 1000000) return label + ': ' + (val / 1000000).toFixed(1) + 'M ₺';
                                if (val >= 1000) return label + ': ' + (val / 1000).toFixed(0) + 'K ₺';
                                return label + ': ' + val.toFixed(0) + ' ₺';
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: "'DM Sans', sans-serif", size: 11, weight: '600' }, color: '#64748b' }
                    },
                    y: {
                        grid: { color: 'rgba(241,245,249,0.8)', drawBorder: false },
                        ticks: {
                            font: { family: "'DM Sans', sans-serif", size: 10 },
                            color: '#94a3b8',
                            callback: function(val) { return val >= 1000000 ? (val / 1000000).toFixed(0) + 'M' : val >= 1000 ? (val / 1000).toFixed(0) + 'K' : val; }
                        },
                        beginAtZero: true
                    }
                },
                animation: { duration: 1200, easing: 'easeOutQuart' }
            }
        });
    }

    /* ══════════════════════════════════
       SATIŞ DÖNGÜSÜ ANALİZİ
       ══════════════════════════════════ */
    function renderSalesCycle(data) {
        var mainEl = document.getElementById('cycleMainNumber');
        if (!mainEl) return;

        var reset = function() {
            mainEl.textContent = '—';
            document.getElementById('cycleDealCount').textContent = 'Veri yok';
            document.getElementById('cycleFirsatTeklif').textContent = '—';
            document.getElementById('cycleTeklifSiparis').textContent = '—';
            document.getElementById('cycleSiparisFatura').textContent = '—';
            document.getElementById('cycleMin').textContent = '—';
            document.getElementById('cycleMedian').textContent = '—';
            document.getElementById('cycleMax').textContent = '—';
            document.getElementById('segFirsatTeklif').style.width = '0%';
            document.getElementById('segTeklifSiparis').style.width = '0%';
            document.getElementById('segSiparisFatura').style.width = '0%';
        };

        if (!data || (data.toplamKapanan === 0 && data.firsatKapanisAdet === 0)) { reset(); return; }

        // Ana metrik: Fırsat oluşturma → Kapanış (Won)
        var firsatKapanis = data.ortFirsatKapanis || 0;
        mainEl.textContent = firsatKapanis > 0 ? firsatKapanis.toFixed(1) : (data.ortToplamDongu || 0).toFixed(1);
        mainEl.classList.remove('num-pulse');
        void mainEl.offsetWidth;
        mainEl.classList.add('num-pulse');
        var dealCount = data.firsatKapanisAdet || data.toplamKapanan || 0;
        document.getElementById('cycleDealCount').textContent = dealCount + ' deal';

        // 3 aşama süreleri
        var ft = data.ortFirsatTeklif || 0;
        document.getElementById('cycleFirsatTeklif').textContent = ft > 0 ? ft.toFixed(0) + ' gün' : '—';
        document.getElementById('cycleTeklifSiparis').textContent = data.ortTeklifSiparis.toFixed(0) + ' gün';
        document.getElementById('cycleSiparisFatura').textContent = data.ortSiparisFatura.toFixed(0) + ' gün';

        // Segmented timeline bar: oransal genişlik
        var total = ft + data.ortTeklifSiparis + data.ortSiparisFatura;
        if (total > 0) {
            setTimeout(function() {
                var pct = function(v) { return Math.max(Math.round(v / total * 100), v > 0 ? 4 : 0) + '%'; };
                document.getElementById('segFirsatTeklif').style.width = pct(ft);
                document.getElementById('segTeklifSiparis').style.width = pct(data.ortTeklifSiparis);
                document.getElementById('segSiparisFatura').style.width = pct(data.ortSiparisFatura);
            }, 200);
        }

        // Alt istatistikler
        document.getElementById('cycleMin').textContent = data.minDongu + ' gün';
        document.getElementById('cycleMedian').textContent = data.medyanToplamDongu.toFixed(0) + ' gün';
        document.getElementById('cycleMax').textContent = data.maxDongu + ' gün';
    }


    var hedefChartInstance = null;
    function renderHedefChart(hedef, opp) {
        var cv = document.getElementById('hedefChart');
        if (!cv || !cv.getContext) return;
        if (hedefChartInstance) hedefChartInstance.destroy();
        var stages = [
            { label: 'Fırsat', value: opp.exFirsatTutar || 0, color: '#8b5cf6' },
            { label: 'Teklif', value: opp.exTeklifTutar || 0, color: '#3b82f6' },
            { label: 'Sipariş', value: opp.exSiparisTutar || 0, color: '#06b6d4' },
            { label: 'Fatura', value: window._faturaData ? window._faturaData.kapaliSiparisTutar : 0, color: '#10b981' }
        ];
        // Y ekseni hedef çizgisini her zaman kapsasın
        var maxBar = Math.max.apply(null, stages.map(function(s) { return s.value; }));
        var yMax = Math.max(maxBar, hedef) * 1.12; // %12 padding
        var cfg = {
            type: 'bar',
            data: {
                labels: stages.map(function(s) { return s.label; }),
                datasets: [{
                    data: stages.map(function(s) { return s.value; }),
                    backgroundColor: stages.map(function(s) { return s.color; }),
                    borderRadius: 6, barThickness: 32
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                animation: { duration: 800, easing: 'easeOutQuart' },
                plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(c) { return abbr(c.raw); } } } },
                scales: {
                    x: { grid: { display: false }, border: { display: false }, ticks: { font: { family: 'DM Sans', size: 10 }, color: '#64748b' } },
                    y: { suggestedMax: yMax, grid: { color: 'rgba(0,0,0,0.04)', drawBorder: false }, border: { display: false }, ticks: { font: { size: 9 }, color: '#94a3b8', callback: function(v) { return v >= 1e6 ? (v/1e6).toFixed(0)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v; } } }
                }
            },
            plugins: [hedefLinePlugin]
        };
        _hedefLineValue = hedef;
        hedefChartInstance = new Chart(cv, cfg);
    }

    /* ══════════════════════════════════
       OWNER PERFORMANCE
       ══════════════════════════════════ */
    async function loadOwnerPerformance() {
        try {
            var data = await fetch('/FirsatAnaliz/GetOwnerPerformance?' + getFilterParams()).then(function(r) { return r.json(); });
            var el = document.getElementById('ownerList');
            if (!data || !data.length) {
                el.innerHTML = '<p class="text-[11px] text-[#94a3b8] text-center py-6">Veri Bulunamadı</p>';
                return;
            }

            var h = '';
            data.slice(0, 12).forEach(function(o, i) {
                var clr = avatarColors[i % avatarColors.length];
                var wrClass = o.kazanmaOrani >= 80 ? 'text-emerald-600' : o.kazanmaOrani >= 50 ? 'text-amber-600' : 'text-red-500';
                h += '<div class="flex items-center gap-3 py-2.5 px-2 rounded-lg hover:bg-[#f8fafc] transition-colors">';
                h += medalHtml(i + 1);
                h += '<div class="avatar-circle" style="background:' + clr + ';">' + initials(o.adSoyad) + '</div>';
                h += '<div class="flex-1 min-w-0">';
                h += '<p class="text-[12px] font-semibold text-[#0f172a] truncate">' + o.adSoyad + '</p>';
                h += '<div class="flex items-center gap-2 mt-1">';
                h += '<span class="text-[10px] text-[#94a3b8]">' + o.won + ' won / ' + o.toplam + ' toplam</span>';
                h += '<span class="text-[10px] font-bold ' + wrClass + '">%' + fmtPct.format(o.kazanmaOrani) + '</span>';
                h += '</div></div>';
                h += '<div class="text-right">';
                h += '<p class="text-[13px] font-bold text-[#0f172a]">' + abbr(o.wonTutar) + '</p>';
                h += '<p class="text-[9px] text-[#94a3b8] font-medium">Kazanilan</p>';
                h += '</div>';
                h += '</div>';
                if (i < data.length - 1 && i < 11) h += '<div class="divider"></div>';
            });
            el.innerHTML = h;
        } catch (e) { console.error('Owner error:', e); }
    }

    /* ══════════════════════════════════
       PRODUCTS
       ══════════════════════════════════ */
    async function loadProducts() {
        try {
            var data = await fetch('/FirsatAnaliz/GetProductPerformance?' + getFilterParams()).then(function(r) { return r.json(); });
            var el = document.getElementById('productBars');
            if (!data || !data.length) {
                el.innerHTML = '<p class="text-[11px] text-[#94a3b8] text-center py-4">Veri Bulunamadı</p>';
                return;
            }

            var max = Math.max.apply(null, data.map(function(d) { return d.teklifTutar; })) || 1;
            var h = '';
            data.slice(0, 8).forEach(function(p) {
                var pct = Math.max((p.teklifTutar / max) * 100, 3);
                h += '<div>';
                h += '<div class="flex items-center justify-between mb-1">';
                h += '<span class="text-[11px] font-semibold text-[#334155]">' + (p.urunGrubu || '--') + '</span>';
                h += '<span class="text-[11px] font-bold text-[#0f172a]">' + abbr(p.teklifTutar) + '</span>';
                h += '</div>';
                h += '<div class="pbar-track"><div class="pbar-fill" style="width:' + pct + '%; background: linear-gradient(90deg, #10b981, #34d399);"></div></div>';
                h += '</div>';
            });
            el.innerHTML = h;
        } catch (e) { console.error('Product error:', e); }
    }

    /* ══════════════════════════════════
       CUSTOMERS
       ══════════════════════════════════ */
    async function loadCustomers() {
        try {
            var data = await fetch('/FirsatAnaliz/GetChartData?chartType=customer&' + getFilterParams()).then(function(r) { return r.json(); });
            var el = document.getElementById('customerBars');
            if (!data || !data.labels || !data.labels.length) {
                el.innerHTML = '<p class="text-[11px] text-[#94a3b8] text-center py-4">Veri Bulunamadı</p>';
                return;
            }

            var vals = data.datasets[0].data;
            var max = Math.max.apply(null, vals) || 1;
            var h = '';
            data.labels.slice(0, 7).forEach(function(lbl, i) {
                var val = vals[i] || 0;
                var pct = Math.max((val / max) * 100, 3);
                h += '<div>';
                h += '<div class="flex items-center justify-between mb-1">';
                h += '<span class="text-[11px] font-semibold text-[#334155] truncate max-w-[200px]">' + (lbl || '--') + '</span>';
                h += '<span class="text-[11px] font-bold text-[#0f172a]">' + abbr(val) + '</span>';
                h += '</div>';
                h += '<div class="pbar-track"><div class="pbar-fill" style="width:' + pct + '%; background: linear-gradient(90deg, #8b5cf6, #a78bfa);"></div></div>';
                h += '</div>';
            });
            el.innerHTML = h;
        } catch (e) { console.error('Customer error:', e); }
    }

