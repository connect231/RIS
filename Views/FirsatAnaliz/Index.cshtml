@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
(function() {
    'use strict';

    /* ══════════════════════════════════
       FORMATTERS
       ══════════════════════════════════ */
    var fmt = new Intl.NumberFormat('tr-TR', { maximumFractionDigits: 0 });
    var fmtPct = new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 1, maximumFractionDigits: 1 });

    function abbr(v) {
        if (v == null) return '-- \u20BA';
        if (v >= 1e9) return (v / 1e9).toFixed(1) + 'B \u20BA';
        if (v >= 1e6) return (v / 1e6).toFixed(1) + 'M \u20BA';
        if (v >= 1e3) return (v / 1e3).toFixed(0) + 'K \u20BA';
        return fmt.format(v) + ' \u20BA';
    }

    /* ── CountUp Animation ── */
    function countUp(el, target, duration, prefix, suffix) {
        prefix = prefix || '';
        suffix = suffix || '';
        duration = duration || 800;
        var start = performance.now();
        function step(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3); // ease-out-cubic
            var current = target * eased;
            el.textContent = prefix + abbr(Math.round(current));
            if (progress < 1) requestAnimationFrame(step);
            else {
                el.textContent = prefix + abbr(target);
                el.classList.add('num-pulse');
                setTimeout(function() { el.classList.remove('num-pulse'); }, 400);
            }
        }
        requestAnimationFrame(step);
    }

    function countUpInt(el, target, duration) {
        duration = duration || 600;
        var start = performance.now();
        function step(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = fmt.format(Math.round(target * eased));
            if (progress < 1) requestAnimationFrame(step);
            else {
                el.textContent = fmt.format(target);
                el.classList.add('num-pulse');
                setTimeout(function() { el.classList.remove('num-pulse'); }, 400);
            }
        }
        requestAnimationFrame(step);
    }

    /* ══════════════════════════════════
       STATE
       ══════════════════════════════════ */
    var activeFilter = 'month';
    var activeFunnel = 0; // 0 = none selected, 1-5 = funnel index
    var oppOwnerVal = '';
    var activeProductFilter = '';
    var activeCustomerFilter = '';
    var activeOwnerFilter = '';

    // Ürün/Müşteri/Temsilci tıklama filtreleri
    window._filterByProduct = function(urun) {
        urun = decodeURIComponent(urun);
        if (activeProductFilter === urun) { activeProductFilter = ''; } else { activeProductFilter = urun; activeCustomerFilter = ''; activeOwnerFilter = ''; }
        refreshLowerSections();
    };
    window._filterByCustomer = function(musteri) {
        musteri = decodeURIComponent(musteri);
        if (activeCustomerFilter === musteri) { activeCustomerFilter = ''; } else { activeCustomerFilter = musteri; activeProductFilter = ''; activeOwnerFilter = ''; }
        refreshLowerSections();
    };
    window._filterByOwner = function(owner) {
        owner = decodeURIComponent(owner);
        if (activeOwnerFilter === owner) { activeOwnerFilter = ''; } else { activeOwnerFilter = owner; activeProductFilter = ''; activeCustomerFilter = ''; }
        refreshLowerSections();
    };

    function getFilterParams() {
        var params = 'filter=' + encodeURIComponent(activeFilter) + '&_t=' + Date.now();
        if (oppOwnerVal) params += '&owner=' + encodeURIComponent(oppOwnerVal);
        return params;
    }

    function donemLabel() {
        switch (activeFilter) {
            case 'lastmonth': return 'Geçen Ay';
            case 'q1': return '1. Çeyrek';
            case 'q2': return '2. Çeyrek';
            case 'q3': return '3. Çeyrek';
            case 'q4': return '4. Çeyrek';
            case 'ytd':  return 'YTD';
            case 'all':  return 'Tüm Dönem';
            default:     return 'Bu Ay';
        }
    }

    /* ══════════════════════════════════
       AVATAR HELPERS
       ══════════════════════════════════ */
    var avatarColors = ['#6366f1','#ec4899','#f59e0b','#10b981','#3b82f6','#8b5cf6','#ef4444','#06b6d4','#f97316','#84cc16'];

    function initials(name) {
        if (!name) return '??';
        var parts = name.trim().split(' ');
        if (parts.length >= 2) return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
        return name.substring(0, 2).toUpperCase();
    }

    function medalHtml(rank) {
        if (rank === 1) return '<span class="medal">\uD83E\uDD47</span>';
        if (rank === 2) return '<span class="medal">\uD83E\uDD48</span>';
        if (rank === 3) return '<span class="medal">\uD83E\uDD49</span>';
        return '<span class="medal text-[12px] text-[#94a3b8] font-semibold">#' + rank + '</span>';
    }

    /* ══════════════════════════════════
       FUNNEL CARD CLICK
       ══════════════════════════════════ */
    // ─── Funnel expand panel — tek trigger, timeline zincir ───
    var _funnelExpanded = 0; // 0 = kapalı, 1 = açık
    window.toggleFunnelExpand = function(_unused) {
        var panel = document.getElementById('funnelExpandPanel');
        var trig  = document.getElementById('funnelSingleTrigger');
        if (_funnelExpanded === 1) {
            _funnelExpanded = 0;
            panel.classList.remove('open');
            panel.setAttribute('aria-hidden', 'true');
            trig.classList.remove('active');
            return;
        }
        _funnelExpanded = 1;
        renderFunnelExpand();
        panel.classList.add('open');
        panel.setAttribute('aria-hidden', 'false');
        trig.classList.add('active');
    };

    function renderFunnelExpand() {
        var host = document.getElementById('funnelExpandContent');
        if (!host) return;
        if (!window._oppData) {
            host.innerHTML = '<p style="color:#94a3b8; font-size:11px;">Veri yükleniyor…</p>';
            return;
        }
        var opp = window._oppData;
        var donem = donemLabel();

        var stages = [
            { label:'Havuz',   adet: opp.tumFirsatAdet || 0,  tutar: opp.tumFirsatTutar || 0,  color:'#3b82f6' },
            { label:'Fırsat',  adet: opp.fnlK2Adet || 0,      tutar: opp.fnlK2Tutar || 0,      color:'#6366f1' },
            { label:'Teklif',  adet: opp.fnlK3Adet || 0,      tutar: opp.fnlK3Tutar || 0,      color:'#8b5cf6' },
            { label:'Sipariş', adet: opp.fnlK4Adet || 0,      tutar: opp.fnlK4Tutar || 0,      color:'#f59e0b' },
            { label:'Fatura',  adet: opp.fnlK5Adet || 0,      tutar: opp.fnlK5Tutar || 0,      color:'#10b981' }
        ];

        function pctClass(pct) {
            if (pct >= 50) return 'high';
            if (pct >= 15) return 'mid';
            return 'low';
        }

        var k1 = stages[0].adet, k5 = stages[4].adet;
        var totalConv = k1 > 0 ? (k5 / k1 * 100) : 0;

        var html = '';
        html += '<div class="fnl-pipe-header">';
        html += '  <span class="fnl-pipe-title">Fırsat zinciri</span>';
        html += '  <span class="fnl-pipe-meta">' + donem + '</span>';
        html += '</div>';
        html += '<div class="fnl-pipe">';

        for (var i = 0; i < stages.length; i++) {
            var s = stages[i];
            html += '<div class="fnl-pipe-stage" style="--stage-color:'+s.color+';">';
            html += '  <div class="fnl-pipe-label">'+s.label+'</div>';
            html += '  <div class="fnl-pipe-tutar">'+abbr(s.tutar)+'</div>';
            html += '  <div class="fnl-pipe-adet">'+s.adet+' adet</div>';
            html += '</div>';

            if (i < stages.length - 1) {
                var next = stages[i+1];
                var pct = s.adet > 0 ? (next.adet / s.adet * 100) : 0;
                html += '<div class="fnl-pipe-conv">';
                html += '  <span class="fnl-pipe-pct '+pctClass(pct)+'">%'+fmtPct.format(pct)+'</span>';
                html += '</div>';
            }
        }
        html += '</div>';

        html += '<div class="fnl-pipe-foot">';
        html += '  <span>Uçtan uca dönüşüm: <b>%'+fmtPct.format(totalConv)+'</b> ('+k5+' / '+k1+')</span>';
        html += '  <span>Adet bazlı</span>';
        html += '</div>';

        host.innerHTML = html;
    }

    // Funnel kart tıklama — tek handler
    var _funnelLoading = false;
    window._clickFunnel = function(idx) {
        if (_funnelLoading) return; // Çift tıklama engeli
        var cards = document.querySelectorAll(".funnel-card");
        if (activeFunnel === idx) {
            activeFunnel = 0;
            cards.forEach(function(c) { c.classList.remove("active-card","dimmed"); });
        } else {
            activeFunnel = idx;
            cards.forEach(function(c) {
                var ci = parseInt(c.dataset.funnel);
                if (ci === idx) { c.classList.add("active-card"); c.classList.remove("dimmed"); }
                else { c.classList.remove("active-card"); c.classList.add("dimmed"); }
            });
        }
        _funnelLoading = true;
        refreshLowerSections().then(function() { _funnelLoading = false; });
    };

    /* ══════════════════════════════════
       LOAD ALL
       ══════════════════════════════════ */
    async function refreshAll() {
        // Tüm kartlar tek SP'den (loadKpis K1-K5 dahil) + breakdown + detay
        await Promise.all([
            loadKpis(),
            loadFunnelBreakdown(activeFunnel > 0 ? activeFunnel : 2),
            loadOppDetail(1),
            loadOwnerOptions(),
            loadSalesCycle()
        ]);
    }

    async function loadSalesCycle() {
        try {
            var data = await fetch('/FirsatAnaliz/GetSalesCycleData?' + getFilterParams()).then(function(r) { return r.json(); });
            renderSalesCycle(data);
        } catch(e) { console.error('SalesCycle error:', e); }
    }

    async function loadFaturaKarti() {
        try {
            var f = await fetch('/FirsatAnaliz/GetFaturaKarti?' + getFilterParams()).then(function(r) { return r.json(); });
            // Kart 5 güncelle
            countUp(document.getElementById('kpiVal5'), f.kapaliSiparisTutar, 700);
            document.getElementById('kpiSub5').textContent = f.kapaliSiparisAdet + ' faturalanan sipariş';
            // Hedef panelini fatura verisiyle güncelle
            window._faturaData = f;
            if (window._hedefTutar && window._hedefTutar > 0) updateHedefWithFatura(f);
            if (_funnelExpanded > 0) renderFunnelExpand();
        } catch(e) { console.error('FaturaKarti error:', e); }
    }

    async function refreshLowerSections() {
        var funnel = activeFunnel > 0 ? activeFunnel : 2;
        await Promise.all([
            loadFunnelBreakdown(funnel),
            loadOppDetail(1)
        ]);
    }

    // iOS-like fade transition
    function fadeOut(el) { el.classList.add('fading'); }
    function fadeIn(el) { el.classList.remove('fading'); }

    async function loadFunnelBreakdown(funnel) {
        try {
            // Fade out all panels
            var panels = document.querySelectorAll('.content-panel');
            panels.forEach(fadeOut);

            var bpParams = getFilterParams() + '&funnel=' + funnel;
            if (activeCustomerFilter) bpParams += '&customer=' + encodeURIComponent(activeCustomerFilter);
            if (activeProductFilter) bpParams += '&product=' + encodeURIComponent(activeProductFilter);
            if (activeOwnerFilter) bpParams += '&ownerName=' + encodeURIComponent(activeOwnerFilter);
            var data = await fetch('/FirsatAnaliz/GetFunnelBreakdown?' + bpParams).then(function(r) { return r.json(); });

            // Kısa fade geçişi (veri geldiğinde hemen render)
            await new Promise(function(r) { setTimeout(r, 80); });

            // Owner/Müşteri listesi güncelle
            var ownerEl = document.getElementById('ownerList');
            if (data.ownerBreakdown && data.ownerBreakdown.length) {
                var h = '';
                data.ownerBreakdown.forEach(function(o, i) {
                    var isActive = activeOwnerFilter === o.adSoyad;
                    h += '<div class="flex items-center gap-3 py-2.5 px-2 rounded-lg cursor-pointer transition-colors '+(isActive ? 'bg-indigo-50 ring-1 ring-indigo-200' : 'hover:bg-[#f8fafc]')+'" onclick="window._filterByOwner(\''+encodeURIComponent(o.adSoyad)+'\')">';
                    h += medalHtml(i + 1);
                    h += '<div class="flex-1 min-w-0">';
                    h += '<p class="text-[12px] font-semibold text-[#0f172a] truncate">'+o.adSoyad+'</p>';
                    h += '<p class="text-[10px] text-[#94a3b8]">'+o.adet+' adet</p>';
                    h += '</div>';
                    h += '<div class="text-right">';
                    h += '<p class="text-[13px] font-bold text-[#0f172a]">'+abbr(o.tutar)+'</p>';
                    h += '</div></div>';
                    if (i < data.ownerBreakdown.length - 1) h += '<div class="divider"></div>';
                });
                ownerEl.innerHTML = h;
            } else ownerEl.innerHTML = '<p class="text-[11px] text-[#94a3b8] text-center py-6">Veri Bulunamadı</p>';

            // Ürün dağılımı
            var prodEl = document.getElementById('productBars');
            if (data.productBreakdown && data.productBreakdown.length) {
                var max = Math.max.apply(null, data.productBreakdown.map(function(p) { return p.tutar; })) || 1;
                var ph = '';
                data.productBreakdown.forEach(function(p) {
                    var pct = Math.max((p.tutar / max) * 100, 3);
                    var isActiveProd = activeProductFilter === p.urun;
                    ph += '<div class="cursor-pointer rounded-lg px-1 py-0.5 -mx-1 transition-colors '+(isActiveProd ? 'bg-emerald-50 ring-1 ring-emerald-200' : 'hover:bg-emerald-50/50')+'" onclick="window._filterByProduct(\''+encodeURIComponent(p.urun)+'\')">';
                    ph += '<div class="flex items-center justify-between mb-1">';
                    ph += '<span class="text-[11px] font-semibold text-[#334155]">'+p.urun+'</span>';
                    ph += '<span class="text-[11px] font-bold text-[#0f172a]">'+abbr(p.tutar)+'</span>';
                    ph += '</div>';
                    ph += '<div class="pbar-track"><div class="pbar-fill" style="width:'+pct+'%; background: linear-gradient(90deg, #10b981, #34d399);"></div></div>';
                    ph += '</div>';
                });
                prodEl.innerHTML = ph;
            } else prodEl.innerHTML = '<p class="text-[11px] text-[#94a3b8] text-center py-4">Veri Bulunamadı</p>';

            // Müşteri dağılımı
            var custEl = document.getElementById('customerBars');
            if (data.customerBreakdown && data.customerBreakdown.length) {
                var cmax = Math.max.apply(null, data.customerBreakdown.map(function(c) { return c.tutar; })) || 1;
                var ch = '';
                data.customerBreakdown.forEach(function(c) {
                    var cpct = Math.max((c.tutar / cmax) * 100, 3);
                    var isActiveCust = activeCustomerFilter === c.musteri;
                    ch += '<div class="cursor-pointer rounded-lg px-1 py-0.5 -mx-1 transition-colors '+(isActiveCust ? 'bg-violet-50 ring-1 ring-violet-200' : 'hover:bg-violet-50/50')+'" onclick="window._filterByCustomer(\''+encodeURIComponent(c.musteri)+'\')">';
                    ch += '<div class="flex items-center justify-between mb-1">';
                    ch += '<span class="text-[11px] font-semibold text-[#334155] truncate max-w-[200px]">'+(c.musteri||'--')+'</span>';
                    ch += '<span class="text-[11px] font-bold text-[#0f172a]">'+abbr(c.tutar)+'</span>';
                    ch += '</div>';
                    ch += '<div class="pbar-track"><div class="pbar-fill" style="width:'+cpct+'%; background: linear-gradient(90deg, #8b5cf6, #a78bfa);"></div></div>';
                    ch += '</div>';
                });
                custEl.innerHTML = ch;
            } else custEl.innerHTML = '';

            // Fade in all panels
            var panels = document.querySelectorAll('.content-panel');
            panels.forEach(fadeIn);

        } catch(e) {
            console.error('FunnelBreakdown error:', e);
            document.querySelectorAll('.content-panel').forEach(fadeIn);
        }

        // Detay tablosu da güncelle
        loadOppDetail(1);
    }

