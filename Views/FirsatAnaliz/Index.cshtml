    /* ══════════════════════════════════
       OPPORTUNITY DETAIL TABLE
       ══════════════════════════════════ */
    async function loadOppDetail(page) {
        var params = getFilterParams() + '&page=' + page + '&pageSize=15';
        if (oppOwnerVal) params += '&owner=' + encodeURIComponent(oppOwnerVal);
        var sf = document.getElementById('oppStageFilter');
        if (sf && sf.value) params += '&stage=' + encodeURIComponent(sf.value);
        if (activeCustomerFilter) params += '&customer=' + encodeURIComponent(activeCustomerFilter);
        if (activeProductFilter) params += '&product=' + encodeURIComponent(activeProductFilter);
        if (activeOwnerFilter) params += '&ownerName=' + encodeURIComponent(activeOwnerFilter);

        // Aktif filtre badge
        var filterBadge = document.getElementById('activeFilterBadge');
        if (activeProductFilter) {
            filterBadge.innerHTML = '<span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-emerald-50 text-emerald-700 text-[10px] font-semibold">Ürün: '+activeProductFilter+' <button onclick="window._filterByProduct(\''+encodeURIComponent(activeProductFilter)+'\')" class="ml-1 text-emerald-400 hover:text-emerald-700">&times;</button></span>';
            filterBadge.classList.remove('hidden');
        } else if (activeCustomerFilter) {
            filterBadge.innerHTML = '<span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-violet-50 text-violet-700 text-[10px] font-semibold">Müşteri: '+activeCustomerFilter+' <button onclick="window._filterByCustomer(\''+encodeURIComponent(activeCustomerFilter)+'\')" class="ml-1 text-violet-400 hover:text-violet-700">&times;</button></span>';
            filterBadge.classList.remove('hidden');
        } else if (activeOwnerFilter) {
            filterBadge.innerHTML = '<span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-indigo-50 text-indigo-700 text-[10px] font-semibold">Temsilci: '+activeOwnerFilter+' <button onclick="window._filterByOwner(\''+encodeURIComponent(activeOwnerFilter)+'\')" class="ml-1 text-indigo-400 hover:text-indigo-700">&times;</button></span>';
            filterBadge.classList.remove('hidden');
        } else {
            filterBadge.classList.add('hidden');
        }

        try {
            var d = await fetch('/FirsatAnaliz/GetOpportunityDetail?' + params).then(function(r) { return r.json(); });
            var tbody = document.getElementById('oppDetailBody');
            if (!d.items || !d.items.length) {
                tbody.innerHTML = '<tr><td colspan="8" class="text-center py-6 text-[#94a3b8] text-[11px]">Veri Bulunamadı</td></tr>';
                document.getElementById('oppPagination').innerHTML = '';
                return;
            }

            var stageMap = {
                Won: 'bg-emerald-50 text-emerald-700',
                Lost: 'bg-red-50 text-red-600',
                Position: 'bg-blue-50 text-blue-700',
                Negotiation: 'bg-amber-50 text-amber-700',
                Proposal: 'bg-violet-50 text-violet-700',
                Demo: 'bg-cyan-50 text-cyan-700',
                ContractPending: 'bg-indigo-50 text-indigo-700',
                InProgress: 'bg-sky-50 text-sky-700'
            };

            var h = '';
            d.items.forEach(function(item) {
                var sc = Object.keys(stageMap).find(function(k) { return item.asama && item.asama.indexOf(k) >= 0; });
                var badge = sc ? stageMap[sc] : 'bg-slate-100 text-slate-600';
                h += '<tr class="border-t border-[#f8fafc] hover:bg-[#fafbfd] transition-colors">';
                h += '<td class="py-2.5 px-2 text-[11px] text-[#334155] font-medium truncate max-w-[200px]" title="' + (item.name || '') + '">' + (item.name || '--') + '</td>';
                h += '<td class="py-2.5 px-2 text-[11px] text-[#334155] truncate max-w-[160px]" title="' + (item.musteri || '') + '">' + (item.musteri || '--') + '</td>';
                h += '<td class="py-2.5 px-2"><span class="stage-badge ' + badge + '">' + (item.asama || '--') + '</span></td>';
                h += '<td class="py-2.5 px-2 text-[11px] text-[#64748b]">' + (item.satisTemsilcisi || '--') + '</td>';
                h += '<td class="py-2.5 px-2 text-[11px] text-[#64748b]">' + (item.anlasmaTipi || '--') + '</td>';
                h += '<td class="py-2.5 px-2 text-[11px] text-right font-semibold text-[#0f172a]">' + (item.tutar != null ? abbr(item.tutar) : '--') + '</td>';
                h += '<td class="py-2.5 px-2 text-[11px] text-center text-[#64748b]">' + (item.kapanisTarihi || '--') + '</td>';
                h += '<td class="py-2.5 px-2 text-[11px] text-[#94a3b8]">' + (item.kaynak || '--') + '</td>';
                h += '</tr>';
            });
            tbody.innerHTML = h;

            // Pagination
            var totalPages = Math.ceil(d.total / d.pageSize);
            var pag = document.getElementById('oppPagination');
            var ph = '<span class="text-[10px] text-[#94a3b8]">' + d.total + ' kayit</span>';
            if (totalPages > 1) {
                for (var p = 1; p <= Math.min(totalPages, 10); p++) {
                    ph += '<button onclick="window._loadOppDetail(' + p + ')" class="pg-btn ' + (p === d.page ? 'active' : '') + '">' + p + '</button>';
                }
                if (totalPages > 10) {
                    ph += '<span class="text-[10px] text-[#94a3b8]">...</span>';
                }
            }
            pag.innerHTML = ph;
        } catch (e) { console.error('Detail error:', e); }
    }
    window._loadOppDetail = loadOppDetail;

    /* ══════════════════════════════════
       EVENT LISTENERS
       ══════════════════════════════════ */

    // Filter tabs
    document.getElementById('filterTabs').addEventListener('click', function(e) {
        var btn = e.target.closest('.ftab');
        if (!btn) return;
        document.querySelectorAll('.ftab').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        activeFilter = btn.dataset.filter;
        // Reset funnel selection on filter change
        activeFunnel = 0;
        document.querySelectorAll('.funnel-card').forEach(function(c) {
            c.classList.remove('active-card', 'dimmed');
        });
        refreshAll();
    });

    // Owner filter
    document.getElementById('oppOwnerFilter').addEventListener('change', function() {
        oppOwnerVal = this.value;
        loadOppDetail(1);
    });

    // Stage filter
    document.getElementById('oppStageFilter').addEventListener('change', function() {
        loadOppDetail(1);
    });

    /* ══════════════════════════════════
       INIT
       ══════════════════════════════════ */
    document.addEventListener('DOMContentLoaded', function() {
        refreshAll();

    });

})();
</script>
