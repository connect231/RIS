@{
    ViewData["Title"] = "Hoşgeldiniz";
}

<div class="flex items-center justify-center min-h-[calc(100vh-3.5rem)] bg-[#f5f5f7]">
    <div class="text-center max-w-lg px-6">
        <!-- Icon -->
        <div class="mb-6">
            <svg width="48" height="48" viewBox="0 0 36 36" fill="none" class="mx-auto opacity-20">
                <rect width="36" height="36" rx="10" fill="#1d1d1f"/>
                <path d="M22 12.5c0-1.5-1.5-2.5-4-2.5s-4 1-4 2.5c0 2 2.5 2.5 4 3.2s4 1.2 4 3.3c0 1.5-1.5 2.5-4 2.5s-4-1-4-2.5" stroke="white" stroke-width="2" stroke-linecap="round" fill="none"/>
                <circle cx="27" cy="9" r="2.5" fill="#6366f1"/>
            </svg>
        </div>

        <h1 class="text-3xl font-semibold text-[#1d1d1f] mb-2">Hoş geldiniz.</h1>
        <p class="text-[#86868b] text-base font-light">
            Revenue Intelligence Systems'e başarıyla giriş yaptınız.
        </p>

        <div class="mt-8 flex items-center justify-center gap-2 text-xs text-[#86868b]/50">
            <div class="w-1.5 h-1.5 rounded-full bg-indigo-500"></div>
            <span>Sistem aktif</span>
        </div>
    </div>
</div>
